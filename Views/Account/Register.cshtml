@{
    Layout = "_Layout";
    ViewData["Title"] = "Đăng ký tài khoản";
}

<div class="container py-5">
    <div class="row justify-content-center align-items-center" style="min-height: 85vh;">
        <div class="col-md-6 col-lg-5">
            <div class="glass-card p-5 animate-fade-in shadow-xl">
                <div class="text-center mb-5">
                    <div class="d-inline-flex p-3 bg-primary bg-opacity-10 rounded-circle mb-4">
                        <i class="bi bi-person-plus-fill text-primary fs-1"></i>
                    </div>
                    <h2 class="fw-bold mb-1">Tạo tài khoản mới</h2>
                    <p class="text-muted small" id="registerSubtitle">Bắt đầu hành trình của bạn ngay hôm nay</p>
                </div>

                <!-- BƯỚC 1: Nhập thông tin đăng ký -->
                <div id="registerSection">
                    <form id="registerForm">
                        <div class="mb-3">
                            <label class="form-label text-muted small fw-bold">Họ và tên</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-0"><i class="bi bi-person"></i></span>
                                <input type="text" id="regName" class="form-control form-control-custom bg-light border-0" placeholder="Nguyễn Văn A" required>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label text-muted small fw-bold">Tên đăng nhập</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-0"><i class="bi bi-at"></i></span>
                                <input type="text" id="regUsername" class="form-control form-control-custom bg-light border-0" placeholder="username123" required>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label text-muted small fw-bold">Địa chỉ Email</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-0"><i class="bi bi-envelope"></i></span>
                                <input type="email" id="regEmail" class="form-control form-control-custom bg-light border-0" placeholder="name@example.com" required>
                            </div>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-6 mb-3">
                                <label class="form-label text-muted small fw-bold">Mật khẩu</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-0"><i class="bi bi-lock"></i></span>
                                    <input type="password" id="regPassword" class="form-control form-control-custom bg-light border-0" placeholder="••••••••" required>
                                </div>
                            </div>
                            <div class="col-md-6 mb-4">
                                <label class="form-label text-muted small fw-bold">Xác nhận</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-0"><i class="bi bi-check-circle"></i></span>
                                    <input type="password" id="regConfirmPassword" class="form-control form-control-custom bg-light border-0" placeholder="••••••••" required>
                                </div>
                            </div>
                        </div>

                        <div id="regError" class="alert alert-danger border-0 rounded-3 small mb-4 text-center py-2" style="display: none;"></div>

                        <button type="submit" id="registerSubmitBtn" class="btn btn-premium w-100 py-3 shadow-sm">
                            <i class="bi bi-send-fill me-2"></i>Tiếp tục & Nhận mã OTP
                        </button>
                    </form>
                </div>

                <!-- BƯỚC 2: Nhập OTP xác thực -->
                <div id="otpRegisterSection" style="display: none;">
                    <div class="alert alert-info border-0 rounded-4 p-3 small mb-4 text-center">
                        <i class="bi bi-info-circle-fill me-2"></i>
                        Mã OTP đã được gửi đến email. Vui lòng kiểm tra và nhập mã xác thực.
                    </div>

                    <div class="mb-4">
                        <label class="form-label text-muted small fw-bold text-center w-100">Mã xác thực (OTP)</label>
                        <input type="text" id="regOtp" class="form-control form-control-custom text-center fw-bold bg-light border-0 tracking-widest fs-2"
                            maxlength="6" placeholder="000000">
                    </div>

                    <div id="regOtpError" class="alert alert-danger border-0 rounded-3 small mb-4 text-center py-2" style="display: none;"></div>
                    <div id="regOtpSuccess" class="alert alert-success border-0 rounded-3 small mb-4 text-center py-2" style="display: none;">
                        <i class="bi bi-check-circle-fill me-1"></i>Đăng ký thành công! Đang chuyển hướng...
                    </div>

                    <button type="button" id="verifyRegisterOtpBtn" class="btn btn-premium w-100 py-3 mb-3 shadow-sm">
                        <i class="bi bi-check-lg me-2"></i>Xác nhận & Tạo tài khoản
                    </button>
                    <button type="button" onclick="location.reload()" class="btn btn-link text-muted small w-100 text-decoration-none">
                        <i class="bi bi-arrow-left me-1"></i>Quay lại chỉnh sửa
                    </button>
                </div>

                <div class="mt-5 text-center border-top pt-4">
                    <p class="text-muted small">Đã có tài khoản? <a href="/Account/Login" class="text-primary fw-bold text-decoration-none">Đăng nhập ngay</a></p>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .tracking-widest { letter-spacing: 0.5rem; }
    .input-group-text { border-radius: 0.875rem 0 0 0.875rem !important; }
    .form-control-custom { border-radius: 0 0.875rem 0.875rem 0 !important; }
    #regOtp { border-radius: 0.875rem !important; }
</style>

@section Scripts {
    <script src="~/js/auth.js"></script>
}
