@{
    Layout = "_Layout";
    ViewData["Title"] = "Settings";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">

            <!-- Header -->
            <div class="mb-4 animate-slide-up">
                <h2 class="fw-bold mb-1"><i class="bi bi-gear-fill me-2 text-primary"></i>Cài đặt</h2>
                <p class="text-muted small">Quản lý các tùy chọn cá nhân của tài khoản bạn</p>
            </div>

            <!-- Thẻ Bảo mật -->
            <div class="card-glass animate-slide-up mb-4">
                <div class="d-flex align-items-center mb-4">
                    <div class="me-3 p-2 rounded-3" style="background: rgba(79,70,229,0.15);">
                        <i class="bi bi-shield-lock-fill text-primary fs-4"></i>
                    </div>
                    <div>
                        <h5 class="fw-bold mb-0">Bảo mật tài khoản</h5>
                        <small class="text-muted">Các tùy chọn xác thực và bảo vệ tài khoản</small>
                    </div>
                </div>

                <!-- Toggle OTP -->
                <div class="d-flex justify-content-between align-items-center p-3 rounded-3" 
                     style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08);">
                    <div>
                        <div class="fw-semibold mb-1">
                            <i class="bi bi-key-fill me-2 text-warning"></i>Xác thực OTP khi đăng nhập
                        </div>
                        <small class="text-muted">Khi bật, mỗi lần đăng nhập hệ thống sẽ gửi mã OTP về email của bạn để xác thực thêm một lớp bảo mật.</small>
                    </div>
                    <div class="ms-4 flex-shrink-0">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" id="otpToggle" 
                                   role="switch" style="width: 3rem; height: 1.5rem; cursor: pointer;">
                        </div>
                    </div>
                </div>

                <div id="otpStatusMsg" class="mt-3 small text-center" style="display: none;"></div>
            </div>

            <!-- Placeholder cho các tính năng Setting tương lai -->
            <div class="card-glass animate-slide-up" style="opacity: 0.5;">
                <div class="d-flex align-items-center mb-3">
                    <div class="me-3 p-2 rounded-3" style="background: rgba(99,102,241,0.10);">
                        <i class="bi bi-bell-fill text-secondary fs-4"></i>
                    </div>
                    <div>
                        <h5 class="fw-bold mb-0">Thông báo</h5>
                        <small class="text-muted">Tùy chỉnh các loại thông báo bạn muốn nhận</small>
                    </div>
                </div>
                <p class="text-muted small mb-0"><i class="bi bi-clock me-1"></i>Tính năng đang được phát triển...</p>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/settings.js"></script>
}
