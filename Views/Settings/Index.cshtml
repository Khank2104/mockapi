@{
    Layout = "_Layout";
    ViewData["Title"] = "Cài đặt hệ thống";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">

            <!-- Header -->
            <div class="mb-5 animate-fade-in">
                <div class="d-flex align-items-center mb-2">
                    <div class="bg-primary bg-opacity-10 p-2 rounded-3 me-3">
                        <i class="bi bi-gear-fill text-primary fs-3"></i>
                    </div>
                    <h2 class="fw-bold mb-0">Cài đặt hệ thống</h2>
                </div>
                <p class="text-muted small ps-5">Quản lý bảo mật và tùy chọn cá nhân của tài khoản bạn</p>
            </div>

            <!-- Bảo mật Section -->
            <div class="glass-card border-0 shadow-sm mb-4 animate-fade-in" style="animation-delay: 0.1s;">
                <div class="card-body p-4 p-md-5">
                    <h5 class="fw-bold mb-4 d-flex align-items-center">
                        <i class="bi bi-shield-check text-success me-2"></i>
                        Bảo mật & Xác thực
                    </h5>

                    <!-- Toggle OTP -->
                    <div class="p-4 rounded-4 mb-4" style="background: var(--primary-light); border: 1px solid rgba(79,70,229,0.1);">
                        <div class="row align-items-center">
                            <div class="col">
                                <div class="fw-bold text-primary mb-1">
                                    <i class="bi bi-mailbox2 me-2"></i>Xác thực OTP qua Email
                                </div>
                                <p class="text-muted small mb-0">
                                    Tăng cường bảo mật bằng cách yêu cầu mã xác minh mỗi khi bạn đăng nhập từ thiết bị mới.
                                </p>
                            </div>
                            <div class="col-auto">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" id="otpToggle" role="switch" style="width: 3.5rem; height: 1.75rem; cursor: pointer;">
                                </div>
                            </div>
                        </div>
                    </div>

                    <div id="otpStatusMsg" class="alert d-none mb-4 animate-fade-in"></div>

                    <!-- Change Password Link -->
                    <a href="/Settings/ChangePassword" class="text-decoration-none group">
                        <div class="d-flex justify-content-between align-items-center p-4 rounded-4 border border-light bg-white hover-effect">
                            <div class="d-flex align-items-center">
                                <div class="bg-danger bg-opacity-10 p-3 rounded-circle me-3 text-danger">
                                    <i class="bi bi-key-fill"></i>
                                </div>
                                <div>
                                    <div class="fw-bold text-dark mb-0">Đổi mật khẩu</div>
                                    <div class="text-muted small">Cập nhật mật khẩu để bảo vệ tài khoản tốt hơn</div>
                                </div>
                            </div>
                            <div class="text-muted">
                                <i class="bi bi-chevron-right fs-5"></i>
                            </div>
                        </div>
                    </a>
                </div>
            </div>

            <!-- Future Settings Placeholder -->
            <div class="glass-card border-0 shadow-sm animate-fade-in" style="animation-delay: 0.2s; opacity: 0.7;">
                <div class="card-body p-4 p-md-5">
                    <div class="d-flex align-items-center text-muted">
                        <div class="bg-secondary bg-opacity-10 p-3 rounded-circle me-3">
                            <i class="bi bi-bell-slash"></i>
                        </div>
                        <div>
                            <div class="fw-bold mb-0">Cấu hình thông báo</div>
                            <div class="small">Tính năng này đang được phát triển...</div>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<style>
    .hover-effect {
        transition: all 0.3s ease;
    }
    .hover-effect:hover {
        background-color: #f8fafc !important;
        border-color: var(--primary) !important;
        transform: translateY(-2px);
        box-shadow: var(--shadow-md);
    }
    .form-check-input:checked {
        background-color: var(--primary);
        border-color: var(--primary);
    }
</style>

@section Scripts {
    <script src="~/js/settings.js"></script>
}
