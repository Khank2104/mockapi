@{
    Layout = "_Layout";
    ViewData["Title"] = "Đổi mật khẩu";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">
            <div class="mb-4 d-flex align-items-center animate-slide-up">
                <a href="/Settings" class="btn btn-light rounded-circle me-3 shadow-sm text-dark d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                    <i class="bi bi-arrow-left"></i>
                </a>
                <div>
                    <h3 class="fw-bold mb-1">Đổi mật khẩu</h3>
                    <p class="text-muted small mb-0">Tạo một mật khẩu mạnh để bảo vệ tài khoản của bạn</p>
                </div>
            </div>

            <div class="card glass-card border-0 shadow-sm animate-slide-up">
                <div class="card-body p-4 p-md-5">
                    <form id="dedicatedChangePasswordForm">
                        <div class="mb-4">
                            <label class="form-label text-muted small fw-bold">Mật khẩu hiện tại</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0"><i class="bi bi-unlock text-muted"></i></span>
                                <input type="password" id="currentPassword" class="form-control bg-light border-start-0" placeholder="••••••••" required>
                            </div>
                        </div>

                        <hr class="my-4" style="border-color: rgba(0,0,0,0.05);">

                        <div class="mb-3">
                            <label class="form-label text-muted small fw-bold">Mật khẩu mới</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0"><i class="bi bi-key text-primary"></i></span>
                                <input type="password" id="newPassword" class="form-control bg-light border-start-0" placeholder="Ít nhất 6 ký tự" required minlength="6">
                            </div>
                        </div>
                        <div class="mb-4">
                            <label class="form-label text-muted small fw-bold">Xác nhận mật khẩu mới</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0"><i class="bi bi-check-circle text-primary"></i></span>
                                <input type="password" id="confirmNewPassword" class="form-control bg-light border-start-0" placeholder="Nhập lại mật khẩu mới" required>
                            </div>
                        </div>

                        <div id="changePwMsg" class="alert" style="display:none; border-radius: 10px;"></div>

                        <div class="d-grid mt-4">
                            <button type="submit" id="btnChangePw" class="btn btn-premium btn-lg" style="border-radius: 10px;">
                                <i class="bi bi-shield-lock me-2"></i>Lưu mật khẩu mới
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const userStr = localStorage.getItem('currentUser');
            if (!userStr) {
                window.location.href = '/Account/Login';
            }
        });

        document.getElementById('dedicatedChangePasswordForm')?.addEventListener('submit', async function (e) {
            e.preventDefault();
            
            const currentPassword = document.getElementById('currentPassword').value;
            const newPassword = document.getElementById('newPassword').value;
            const confirmNewPassword = document.getElementById('confirmNewPassword').value;
            const msgBox = document.getElementById('changePwMsg');
            const btn = document.getElementById('btnChangePw');

            if (newPassword !== confirmNewPassword) {
                msgBox.className = 'alert alert-danger mt-3';
                msgBox.innerHTML = '<i class="bi bi-exclamation-triangle-fill me-2"></i>Mật khẩu xác nhận không khớp.';
                msgBox.style.display = 'block';
                return;
            }

            if (newPassword.length < 6) {
                msgBox.className = 'alert alert-warning mt-3';
                msgBox.innerHTML = '<i class="bi bi-info-circle-fill me-2"></i>Mật khẩu mới phải có ít nhất 6 ký tự.';
                msgBox.style.display = 'block';
                return;
            }

            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Đang xử lý...';

            try {
                const response = await fetch(`/api/UserProxy/ChangePassword`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ currentPassword, newPassword })
                });

                const result = await response.json();

                if (result.success) {
                    msgBox.className = 'alert alert-success mt-3';
                    msgBox.innerHTML = '<i class="bi bi-check-circle-fill me-2"></i>Đổi mật khẩu thành công!';
                    msgBox.style.display = 'block';
                    this.reset();
                    
                    // Tùy chọn: Chuyển hướng về trang Settings sau 2 giây
                    setTimeout(() => window.location.href = '/Settings', 2000);
                } else {
                    msgBox.className = 'alert alert-danger mt-3';
                    msgBox.innerHTML = `<i class="bi bi-exclamation-triangle-fill me-2"></i>${result.message || 'Đổi mật khẩu thất bại.'}`;
                    msgBox.style.display = 'block';
                }
            } catch (err) {
                msgBox.className = 'alert alert-danger mt-3';
                msgBox.innerHTML = '<i class="bi bi-wifi-off me-2"></i>Lỗi kết nối tới máy chủ.';
                msgBox.style.display = 'block';
            } finally {
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-shield-lock me-2"></i>Lưu mật khẩu mới';
            }
        });
    </script>
}
