@{
    Layout = "_TenantLayout";
    ViewData["Title"] = "Hóa đơn của tôi";
}

<div class="profile-container animate-fade-in">
    <div class="row justify-content-center">
        <div class="col-lg-11">
            <!-- Financial Summary Row -->
            <div class="row g-4 mb-5">
                <div class="col-md-4">
                    <div class="glass-card border-0 shadow-premium p-4 h-100 stats-card">
                        <div class="d-flex align-items-center mb-3">
                            <div class="stat-icon-mini bg-success-soft text-success me-3">
                                <i class="bi bi-wallet2"></i>
                            </div>
                            <h6 class="fw-bold mb-0">Số dư hiện tại</h6>
                        </div>
                        <h2 class="fw-extrabold mb-1" id="current-balance">0 đ</h2>
                        <div class="d-flex align-items-center gap-2">
                            <div id="balance-indicator" class="dot-indicator"></div>
                            <span class="x-small text-muted fw-medium" id="balance-status">Đang tải...</span>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="glass-card border-0 shadow-premium p-4 h-100 stats-card">
                        <div class="d-flex align-items-center mb-3">
                            <div class="stat-icon-mini bg-primary-soft text-primary me-3">
                                <i class="bi bi-cash-coin"></i>
                            </div>
                            <h6 class="fw-bold mb-0">Đã đóng tháng này</h6>
                        </div>
                        <h2 class="fw-extrabold mb-1 text-primary" id="paid-this-month">0 đ</h2>
                        <p class="x-small text-muted mb-0 fw-medium">Thanh toán đã được xác nhận</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="glass-card border-0 shadow-premium p-4 h-100 stats-card premium-hero-banner text-white">
                        <div class="d-flex align-items-center mb-3">
                            <div class="stat-icon-mini bg-white bg-opacity-20 text-white me-3">
                                <i class="bi bi-clock-history"></i>
                            </div>
                            <h6 class="fw-bold mb-0">Tổng chưa thanh toán</h6>
                        </div>
                        <h2 class="fw-extrabold mb-1" id="total-pending">0 đ</h2>
                        <p class="x-small opacity-75 mb-0 fw-medium">Vui lòng hoàn tất sớm nhất có thể</p>
                    </div>
                </div>
            </div>

            <!-- Invoice History List -->
            <div class="glass-card border-0 shadow-premium p-4 p-md-5">
                <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
                    <h4 class="fw-bold mb-0 text-main"><i class="bi bi-receipt-cutoff me-2 text-primary"></i>Lịch sử hóa đơn</h4>
                    <div class="d-flex align-items-center gap-2">
                        <span class="badge bg-secondary bg-opacity-10 text-secondary rounded-pill px-3 py-2 x-small fw-bold">
                            TỔNG CỘNG: <span id="invoice-count" class="text-primary">0</span> BẢN GHI
                        </span>
                    </div>
                </div>

                <div id="invoice-list-container" class="dashboard-list">
                    <!-- Invoices populated by JS -->
                    <div class="text-center py-5">
                        <div class="spinner-border text-primary opacity-50 mb-3" role="status"></div>
                        <div class="x-small text-muted fw-medium">Hệ thống đang trích xuất dữ liệu hóa đơn...</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Invoice Detail Modal -->
<div class="modal fade" id="invoiceDetailModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-5 shadow-lg">
            <div class="modal-body p-5" id="invoice-detail-content">
                <!-- Content populated by JS -->
            </div>
            <div class="modal-footer border-0 p-4">
                <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Đóng</button>
                <button type="button" class="btn btn-premium rounded-pill px-4">Thanh toán ngay</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/modules/tenant/billing.js" asp-append-version="true"></script>
}
