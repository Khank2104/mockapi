@{
    Layout = "_TenantLayout";
    ViewData["Title"] = "Hóa đơn của tôi";
}

<link rel="stylesheet" href="~/css/tenants/tenant-portal.css" asp-append-version="true" />

<div class="profile-container animate-fade-in">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="row g-3 mb-5">
                <div class="col-md-4">
                    <div class="glass-card p-4 rounded-5 border-0 shadow-sm h-100">
                        <div class="small text-muted mb-1 fw-bold text-uppercase">Số dư hiện tại</div>
                        <h2 class="fw-bold mb-0" id="current-balance">0 đ</h2>
                        <div class="mt-2 small" id="balance-status">Đang tải...</div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="glass-card p-4 rounded-5 border-0 shadow-sm h-100">
                        <div class="small text-muted mb-1 fw-bold text-uppercase">Đã đóng tháng này</div>
                        <h2 class="fw-bold mb-0 text-primary" id="paid-this-month">0 đ</h2>
                        <div class="mt-2 small text-muted">Thanh toán ghi nhận bởi Admin</div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="glass-card p-4 rounded-5 border-0 shadow-sm h-100 bg-primary bg-gradient text-white">
                        <div class="small opacity-75 mb-1 fw-bold text-uppercase">Phải thanh toán</div>
                        <h2 class="fw-bold mb-0" id="total-pending">0 đ</h2>
                        <div class="mt-2 small opacity-75">Tổng các hóa đơn chưa đóng</div>
                    </div>
                </div>
            </div>

            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3 class="profile-section-title mb-0"><i class="bi bi-receipt-cutoff"></i> Lịch sử hóa đơn</h3>
                <div class="text-muted small fw-bold"><span id="invoice-count">0</span> hóa đơn</div>
            </div>

            <div id="invoice-list-container">
                <!-- Invoices populated by JS -->
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Invoice Detail Modal -->
<div class="modal fade" id="invoiceDetailModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-5 shadow-lg">
            <div class="modal-body p-5" id="invoice-detail-content">
                <!-- Content populated by JS -->
            </div>
            <div class="modal-footer border-0 p-4">
                <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Đóng</button>
                <button type="button" class="btn btn-premium rounded-pill px-4">Thanh toán ngay</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/tenants/billing.js" asp-append-version="true"></script>
}
