@{
    ViewData["Title"] = "Bảng điều khiển";
}

<div class="container py-5">
    <div class="row g-4 mb-5 animate-fade-in">
        <div class="col-lg-8">
            <div class="card-glass p-5 h-100 border-0 overflow-hidden position-relative" style="background: linear-gradient(135deg, #ffffff 0%, #f1f5f9 100%);">
                <div class="position-absolute top-0 end-0 p-4 opacity-10">
                    <i class="bi bi-rocket-takeoff-fill" style="font-size: 10rem;"></i>
                </div>
                <div class="position-relative">
                    <h4 class="text-primary fw-bold mb-2">Chào mừng trở lại!</h4>
                    <h1 class="display-5 fw-bold mb-4" id="userNameDisplay">Đang tải...</h1>
                    <p class="lead text-muted mb-4" style="max-width: 500px;">
                        Chào mừng bạn đến với hệ thống quản lý tập trung. Tại đây bạn có thể quản lý hồ sơ cá nhân, nhận thông báo quan trọng và tùy chỉnh bảo mật tài khoản.
                    </p>
                    <div class="d-flex gap-3">
                        <a href="/Home/Profile" class="btn btn-primary-custom px-4 py-3">
                            <i class="bi bi-person-badge me-2"></i>Xem hồ sơ
                        </a>
                        <a href="/Settings" class="btn btn-outline-secondary border-2 px-4 py-3" style="border-radius: 0.875rem;">
                            <i class="bi bi-shield-lock me-2"></i>Bảo mật
                        </a>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="stat-card h-100 d-flex flex-column justify-content-center align-items-center text-center p-5 border-0">
                <div class="avatar-wrapper mb-4">
                    <img id="userAvatarLarge" src="" class="rounded-circle border border-4 border-white shadow-lg" style="width: 120px; height: 120px; object-fit: cover;">
                </div>
                <h4 id="userNameSmall" class="fw-bold mb-1">...</h4>
                <p id="userRoleBadge" class="badge rounded-pill bg-primary px-3 py-2 mb-4">Member</p>
                <div class="w-100 pt-4 border-top">
                    <div class="row text-center">
                        <div class="col-6 border-end">
                            <h5 class="fw-bold mb-0">100%</h5>
                            <small class="text-muted x-small">Hoàn thiện</small>
                        </div>
                        <div class="col-6">
                            <h5 class="fw-bold mb-0 text-success">Online</h5>
                            <small class="text-muted x-small">Trạng thái</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 animate-fade-in" style="animation-delay: 0.1s;">
        <div class="col-md-4">
            <div class="card-glass p-4 border-0 hover-effect">
                <div class="stat-icon bg-info bg-opacity-10 text-info">
                    <i class="bi bi-bell-fill"></i>
                </div>
                <h5 class="fw-bold">Thông báo mới</h5>
                <p class="text-muted small">Kiểm tra các cập nhật quan trọng từ hệ thống dành riêng cho bạn.</p>
                <a href="#" class="text-decoration-none small fw-bold" onclick="document.querySelector('#navNotification a').click()">Xem ngay <i class="bi bi-arrow-right"></i></a>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card-glass p-4 border-0 hover-effect">
                <div class="stat-icon bg-success bg-opacity-10 text-success">
                    <i class="bi bi-safe2-fill"></i>
                </div>
                <h5 class="fw-bold">Bảo mật OTP</h5>
                <p class="text-muted small">Nâng cao an toàn cho tài khoản bằng cách kích hoạt xác thực 2 lớp qua Email.</p>
                <a href="/Settings" class="text-decoration-none small fw-bold">Thiết lập <i class="bi bi-arrow-right"></i></a>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card-glass p-4 border-0 hover-effect">
                <div class="stat-icon bg-warning bg-opacity-10 text-warning">
                    <i class="bi bi-person-gear"></i>
                </div>
                <h5 class="fw-bold">Hồ sơ cá nhân</h5>
                <p class="text-muted small">Cập nhật ảnh đại diện, địa chỉ và thông tin liên hệ của bạn.</p>
                <a href="/Home/Profile" class="text-decoration-none small fw-bold">Chỉnh sửa <i class="bi bi-arrow-right"></i></a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const userStr = localStorage.getItem('currentUser');
            if (!userStr) {
                window.location.href = '/Account/Login';
                return;
            }
            const user = JSON.parse(userStr);
            
            document.getElementById('userNameDisplay').innerText = user.name;
            document.getElementById('userNameSmall').innerText = user.name;
            document.getElementById('userAvatarLarge').src = user.avatar || `https://ui-avatars.com/api/?name=${encodeURIComponent(user.name)}&background=random&size=120`;
            
            const badge = document.getElementById('userRoleBadge');
            badge.innerText = user.role.toUpperCase();
            if (user.role === 'admin' || user.role === 'superuser') {
                badge.className = 'badge rounded-pill bg-danger px-3 py-2 mb-4';
            }
        });

        function logout() {
            localStorage.removeItem('currentUser');
            window.location.href = '/Account/Login';
        }
    </script>
}
