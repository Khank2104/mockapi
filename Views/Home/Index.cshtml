@{
    Layout = "_TenantLayout";
    ViewData["Title"] = "Bảng điều khiển khách thuê";
}

<div class="animate-fade-in">
    <!-- Hero Summary Section -->
    <div class="glass-card premium-hero-banner border-0 p-4 p-md-5 mb-5 overflow-hidden position-relative shadow-premium">
        <div class="row align-items-center position-relative" style="z-index: 2;">
            <div class="col-md-7">
                <div class="badge bg-white bg-opacity-20 text-white p-2 px-3 rounded-pill mb-3 border border-white border-opacity-25">
                    <i class="bi bi-stars me-2"></i>Cư dân tiêu chuẩn
                </div>
                <h1 class="fw-extrabold text-white mb-3 display-6">Xin chào cư dân! 👋</h1>
                <p class="text-white opacity-75 mb-4 fs-5 fw-medium">Chào mừng bạn đến với tổ ấm của mình. Mọi thông tin về phòng ở và hóa đơn đều được quản lý tại đây.</p>
                <div class="d-flex flex-wrap gap-3">
                    <a href="/Home/MyInvoices" class="btn btn-white-glass px-4 py-2">
                        <i class="bi bi-wallet2 me-2"></i>Thanh toán ngay
                    </a>
                    <a href="/Home/MySupport" class="btn btn-outline-white-glass px-4 py-2">
                        <i class="bi bi-chat-dots me-2"></i>Gửi hỗ trợ
                    </a>
                </div>
            </div>
            <div class="col-md-5 d-none d-md-block text-center">
                <div class="hero-illustration-wrapper">
                    <img src="https://cdn-icons-png.flaticon.com/512/1042/1042304.png" class="img-fluid floating-animation" style="max-width: 240px; filter: drop-shadow(0 20px 40px rgba(0,0,0,0.3));" />
                </div>
            </div>
        </div>
        <div class="hero-bg-shapes">
            <div class="shape shape-1"></div>
            <div class="shape shape-2"></div>
        </div>
    </div>

    <!-- Quick Access Grid -->
    <div class="row g-4 mb-5">
        <div class="col-6 col-md-3">
            <a href="/Home/MyRoom" class="glass-card quick-access-card border-0 p-4 d-block text-center text-decoration-none shadow-sm hover-up">
                <div class="icon-circle bg-info-gradient text-white mx-auto mb-3 shadow-info">
                    <i class="bi bi-door-open-fill fs-4"></i>
                </div>
                <h6 class="fw-bold mb-1">Phòng của tôi</h6>
                <p class="xx-small text-muted mb-0 uppercase fw-bold opacity-50">Thành viên & Tiện nghi</p>
            </a>
        </div>
        <div class="col-6 col-md-3">
            <a href="/Home/MyInvoices" class="glass-card quick-access-card border-0 p-4 d-block text-center text-decoration-none shadow-sm hover-up">
                <div class="icon-circle bg-success-gradient text-white mx-auto mb-3 shadow-success">
                    <i class="bi bi-receipt-cutoff fs-4"></i>
                </div>
                <h6 class="fw-bold mb-1">Hóa đơn</h6>
                <p class="xx-small text-muted mb-0 uppercase fw-bold opacity-50">Thanh toán hằng tháng</p>
            </a>
        </div>
        <div class="col-6 col-md-3">
            <a href="/Home/MySupport" class="glass-card quick-access-card border-0 p-4 d-block text-center text-decoration-none shadow-sm hover-up">
                <div class="icon-circle bg-warning-gradient text-white mx-auto mb-3 shadow-warning">
                    <i class="bi bi-tools fs-4"></i>
                </div>
                <h6 class="fw-bold mb-1">Sửa chữa</h6>
                <p class="xx-small text-muted mb-0 uppercase fw-bold opacity-50">Yêu cầu & Hỗ trợ</p>
            </a>
        </div>
        <div class="col-6 col-md-3">
            <a href="/Home/Profile" class="glass-card quick-access-card border-0 p-4 d-block text-center text-decoration-none shadow-sm hover-up">
                <div class="icon-circle bg-primary-gradient text-white mx-auto mb-3 shadow-primary">
                    <i class="bi bi-person-badge-fill fs-4"></i>
                </div>
                <h6 class="fw-bold mb-1">Hồ sơ</h6>
                <p class="xx-small text-muted mb-0 uppercase fw-bold opacity-50">Cá nhân & Bảo mật</p>
            </a>
        </div>
    </div>

    <!-- Summary Data Row -->
    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="glass-card border-0 shadow-premium p-4 h-100 stats-card">
                <div class="d-flex align-items-center mb-3">
                    <div class="stat-icon-mini bg-success-soft text-success me-3">
                        <i class="bi bi-wallet2"></i>
                    </div>
                    <h6 class="fw-bold mb-0">Số dư hiện tại</h6>
                </div>
                <h3 class="fw-extrabold mb-1" id="dash-balance">0 đ</h3>
                <div class="d-flex align-items-center gap-2">
                    <div id="dash-balance-indicator" class="dot-indicator"></div>
                    <span class="x-small text-muted fw-medium" id="dash-balance-note">Đang cập nhật...</span>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="glass-card border-0 shadow-premium p-4 h-100 stats-card">
                <div class="d-flex align-items-center mb-3">
                    <div class="stat-icon-mini bg-primary-soft text-primary me-3">
                        <i class="bi bi-cash-coin"></i>
                    </div>
                    <h6 class="fw-bold mb-0">Đã đóng tháng này</h6>
                </div>
                <h3 class="fw-extrabold mb-1" id="dash-paid-this-month">0 đ</h3>
                <p class="x-small text-muted mb-0 fw-medium">Tháng @DateTime.Now.Month/@DateTime.Now.Year</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="glass-card border-0 shadow-premium p-4 h-100 stats-card">
                <div class="d-flex align-items-center mb-3">
                    <div class="stat-icon-mini bg-danger-soft text-danger me-3">
                        <i class="bi bi-exclamation-triangle"></i>
                    </div>
                    <h6 class="fw-bold mb-0">Yêu cầu chờ xử lý</h6>
                </div>
                <h3 class="fw-extrabold mb-1" id="dash-pending-requests">0</h3>
                <p class="x-small text-muted mb-0 fw-medium">Cần admin phản hồi</p>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-7">
            <div class="glass-card border-0 shadow-premium p-4">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="fw-bold mb-0"><i class="bi bi-receipt me-2 text-primary"></i>Hóa đơn gần đây</h5>
                    <a href="/Home/MyInvoices" class="btn btn-link-premium">Xem tất cả <i class="bi bi-arrow-right"></i></a>
                </div>
                <div id="dashboard-invoice-summary" class="dashboard-list">
                    <div class="text-center py-5">
                        <div class="spinner-border spinner-border-sm text-primary opacity-50 mb-2"></div>
                        <div class="x-small text-muted">Đang tải hóa đơn...</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="glass-card border-0 shadow-premium p-4">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="fw-bold mb-0"><i class="bi bi-chat-left-dots me-2 text-warning"></i>Hỗ trợ gần đây</h5>
                    <a href="/Home/MySupport" class="btn btn-link-premium">Gửi mới <i class="bi bi-plus-circle"></i></a>
                </div>
                <div id="dashboard-request-summary" class="dashboard-list">
                    <div class="text-center py-5">
                        <div class="spinner-border spinner-border-sm text-warning opacity-50 mb-2"></div>
                        <div class="x-small text-muted">Đang tải yêu cầu...</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            loadDashboardData();
        });

        async function loadDashboardData() {
            // Load Invoices & Balance Summary
            try {
                const invRes = await fetch('/api/TenantPortal/MyInvoices');
                const invResult = await invRes.json();
                if (invResult.success) {
                    const data = invResult.data;
                    const balance = data.balance || 0;
                    const invoices = data.invoices || [];

                    // Update Balance UI
                    const balanceEl = document.getElementById('dash-balance');
                    const balanceNoteEl = document.getElementById('dash-balance-note');
                    balanceEl.innerText = `${balance.toLocaleString('vi-VN')} đ`;
                    
                    if (balance > 0) {
                        balanceEl.className = 'fw-bold mb-1 text-success';
                        balanceNoteEl.innerText = 'Bạn đang có tiền dư trong hệ thống';
                    } else if (balance < 0) {
                        balanceEl.className = 'fw-bold mb-1 text-danger';
                        balanceNoteEl.innerText = 'Bạn còn khoản nợ chưa thanh toán';
                    } else {
                        balanceEl.className = 'fw-bold mb-1';
                        balanceNoteEl.innerText = 'Số dư hiện tại sạch sẽ';
                    }

                    // Calculate Paid This Month
                    const now = new Date();
                    const currentMonth = now.getMonth() + 1;
                    const currentYear = now.getFullYear();
                    const paidThisMonth = invoices
                        .filter(i => i.billingMonth === currentMonth && i.billingYear === currentYear)
                        .reduce((sum, i) => sum + (i.paidAmount || 0), 0);
                    
                    document.getElementById('dash-paid-this-month').innerText = `${paidThisMonth.toLocaleString('vi-VN')} đ`;

                    // Update Invoices List
                    const unpaid = invoices.filter(i => i.invoiceStatus !== 'Paid').slice(0, 4);
                    const container = document.getElementById('dashboard-invoice-summary');
                    if (unpaid.length === 0) {
                        container.innerHTML = '<div class="alert alert-secondary bg-secondary bg-opacity-10 border-0 rounded-4 p-4 text-center">🎉 Tuyệt vời! Bạn không còn hóa đơn nào chưa thanh toán.</div>';
                    } else {
                        container.innerHTML = unpaid.map(i => `
                            <div class="d-flex justify-content-between align-items-center p-3 mb-2 bg-secondary bg-opacity-10 rounded-4 hover-card">
                                <div>
                                    <div class="fw-bold">Tháng ${i.billingMonth}/${i.billingYear}</div>
                                    <div class="small text-muted">Hạn chốt: ${new Date(i.dueDate).toLocaleDateString('vi-VN')}</div>
                                </div>
                                <div class="text-end">
                                    <div class="fw-bold ${i.invoiceStatus === 'Unpaid' ? 'text-danger' : 'text-warning'}">${i.totalAmount.toLocaleString('vi-VN')} đ</div>
                                    <span class="badge ${i.invoiceStatus === 'Unpaid' ? 'bg-danger' : 'bg-warning'} bg-opacity-10 ${i.invoiceStatus === 'Unpaid' ? 'text-danger' : 'text-warning'} x-small mb-1 d-block">${i.invoiceStatus}</span>
                                    <a href="/Home/MyInvoices" class="small text-primary fw-bold text-decoration-none">Chi tiết</a>
                                </div>
                            </div>
                        `).join('');
                    }
                }
            } catch (e) {
                console.error("Failed to load invoices", e);
            }

            // Load Requests Summary
            try {
                const reqRes = await fetch('/api/TenantPortal/MyRequests');
                const reqResult = await reqRes.json();
                if (reqResult.success) {
                    const requests = reqResult.data || [];
                    const pendingCount = requests.filter(r => r.status === 'Pending' || r.status === 'InProgress').length;
                    document.getElementById('dash-pending-requests').innerText = pendingCount;

                    const container = document.getElementById('dashboard-request-summary');
                    if (requests.length === 0) {
                        container.innerHTML = '<div class="text-center py-4 opacity-50">Chưa có yêu cầu hỗ trợ nào.</div>';
                    } else {
                        container.innerHTML = requests.slice(0, 4).map(r => `
                            <div class="p-3 mb-2 border-bottom border-secondary border-opacity-10 hover-card">
                                <div class="d-flex justify-content-between mb-1">
                                    <span class="small fw-bold">${r.title}</span>
                                    <span class="badge ${getStatusBadge(r.status)} rounded-pill x-small">${r.status}</span>
                                </div>
                                <div class="x-small text-muted">${new Date(r.createdAt).toLocaleDateString('vi-VN')}</div>
                            </div>
                        `).join('');
                    }
                }
            } catch (e) {
                console.error("Failed to load requests", e);
            }
        }

        function getStatusBadge(status) {
            switch(status.toLowerCase()) {
                case 'pending': return 'bg-warning bg-opacity-10 text-warning';
                case 'inprogress': return 'bg-primary';
                case 'resolved': return 'bg-success';
                default: return 'bg-secondary';
            }
        }
    </script>
}

<style>
    .btn-white { background: white; color: var(--primary-color); border: none; }
    .btn-white:hover { background: rgba(255,255,255,0.9); transform: translateY(-2px); }
    .btn-outline-white { border: 2px solid white; color: white; background: transparent; }
    .btn-outline-white:hover { background: rgba(255,255,255,0.1); color: white; }

    .quick-access-card {
        display: block;
        background: var(--bs-body-bg);
        padding: 1.5rem;
        border-radius: 24px;
        text-decoration: none;
        transition: all 0.3s ease;
        text-align: center;
        border: 1px solid var(--bs-border-color-translucent);
    }
    .quick-access-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 30px rgba(0,0,0,0.08) !important;
    }
    .quick-access-card .icon-box {
        width: 60px;
        height: 60px;
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1rem;
        font-size: 1.5rem;
    }
    .quick-access-card h6 { margin-bottom: 0.25rem; color: var(--bs-heading-color); }
</style>
