@{
    Layout = "_TenantLayout";
    ViewData["Title"] = "Cổng thông tin khách thuê";
}

<div class="row g-4 animate-fade-in">
    <!-- Left Column: Room Info & Invoices -->
    <div class="col-lg-8">
        <div class="glass-card mb-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3 class="fw-bold fs-5">Thông tin phòng hiện tại</h3>
                <span class="status-pill status-active" id="room-status-badge">Đang thuê</span>
            </div>
            <div id="room-info-display">
                <div class="text-center py-4 text-muted small">Đang tải thông tin...</div>
            </div>
        </div>

        <div class="glass-card">
            <h3 class="fw-bold fs-5 mb-4">Hóa đơn & Lịch sử thanh toán</h3>
            <div class="table-container">
                <table class="premium-table">
                    <thead>
                        <tr>
                            <th>KỲ THANH TOÁN</th>
                            <th>TỔNG TIỀN</th>
                            <th>TRẠNG THÁI</th>
                            <th>HẠN CHỐT</th>
                            <th>HÀNH ĐỘNG</th>
                        </tr>
                    </thead>
                    <tbody id="invoice-list-display">
                        <tr><td colspan="5" class="text-center py-5 text-muted">Đang tải hóa đơn...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Right Column: Support & History -->
    <div class="col-lg-4">
        <div class="glass-card mb-4">
            <h3 class="fw-bold fs-5 mb-3">Gửi yêu cầu hỗ trợ</h3>
            <p class="text-muted small mb-4">Gặp vấn đề về điện, nước hay cơ sở vật chất? Hãy báo ngay cho chúng tôi.</p>
            
            <form id="requestForm">
                <div class="mb-3">
                    <label class="form-label small fw-bold opacity-75">TIÊU ĐỀ</label>
                    <input type="text" name="Title" class="form-control" placeholder="Ví dụ: Hỏng bóng đèn..." style="border-radius: 12px;">
                </div>
                <div class="mb-3">
                    <label class="form-label small fw-bold opacity-75">LOẠI YÊU CẦU</label>
                    <select name="RequestType" class="form-select" style="border-radius: 12px;">
                        <option value="Repair">Sửa chữa</option>
                        <option value="Complaint">Khiếu nại</option>
                        <option value="Other">Khác</option>
                    </select>
                </div>
                <div class="mb-4">
                    <label class="form-label small fw-bold opacity-75">MÔ TẢ CHI TIẾT</label>
                    <textarea name="Description" class="form-control" rows="3" placeholder="Nhà vệ sinh bị rò nước..." style="border-radius: 12px;"></textarea>
                </div>
                <button type="button" class="btn btn-premium w-100 py-3" onclick="submitRequest()">
                    Gửi yêu cầu <i class="bi bi-send-fill ms-2"></i>
                </button>
            </form>
        </div>

        <div class="glass-card">
            <h3 class="fw-bold fs-6 mb-3">Yêu cầu gần đây</h3>
            <div id="request-history-list">
                <div class="text-center py-3 text-muted small">Đang tải...</div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            loadTenantData();
        });

        async function loadTenantData() {
            loadRoomInfo();
            loadInvoices();
            loadRequests();
        }

        async function loadRoomInfo() {
            const container = document.getElementById('room-info-display');
            try {
                const response = await fetch('/api/TenantPortal/MyRoomInfo');
                const result = await response.json();
                if (result.success && result.data) {
                    const r = result.data;
                    container.innerHTML = `
                        <div class="row g-4">
                            <div class="col-md-6">
                                <div class="p-3 bg-light rounded-4">
                                    <div class="x-small text-muted fw-bold mb-1">MÃ PHÒNG</div>
                                    <div class="fw-bold fs-4 text-primary">${r.roomCode}</div>
                                    <div class="small text-muted">${r.motelName}</div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="p-3 bg-light rounded-4">
                                    <div class="x-small text-muted fw-bold mb-1">TIỀN THUÊ CỐ ĐỊNH</div>
                                    <div class="fw-bold fs-4">${r.monthlyRent.toLocaleString('vi-VN')}đ</div>
                                    <div class="small text-muted">Hợp đồng: ${new Date(r.checkInDate).toLocaleDateString('vi-VN')}</div>
                                </div>
                            </div>
                        </div>
                    `;
                } else {
                    container.innerHTML = '<div class="alert alert-info border-0 rounded-4 py-3 small">Bạn hiện chưa có hợp đồng phòng nào đang hoạt động.</div>';
                }
            } catch (e) {
                container.innerHTML = '<div class="text-danger small">Lỗi khi tải dữ liệu phòng.</div>';
            }
        }

        async function loadInvoices() {
            const list = document.getElementById('invoice-list-display');
            try {
                const response = await fetch('/api/TenantPortal/MyInvoices');
                const result = await response.json();
                if (result.success) {
                    if (result.data.length === 0) {
                        list.innerHTML = '<tr><td colspan="5" class="text-center py-5">Chưa có hóa đơn nào được phát hành.</td></tr>';
                        return;
                    }
                    list.innerHTML = result.data.map(i => `
                        <tr>
                            <td><span class="fw-bold">Tháng ${i.billingMonth}/${i.billingYear}</span></td>
                            <td class="text-primary fw-bold">${i.totalAmount.toLocaleString('vi-VN')}đ</td>
                            <td><span class="status-pill status-${i.invoiceStatus.toLowerCase() === 'unpaid' ? 'locked' : 'active'}">${i.invoiceStatus === 'Unpaid' ? 'Chưa thanh toán' : 'Đã thanh toán'}</span></td>
                            <td class="text-muted small">${new Date(i.dueDate).toLocaleDateString('vi-VN')}</td>
                            <td>
                                <button class="btn btn-sm btn-outline-primary rounded-pill px-3">Chi tiết</button>
                            </td>
                        </tr>
                    `).join('');
                }
            } catch (e) {}
        }

        async function loadRequests() {
            const container = document.getElementById('request-history-list');
            try {
                const response = await fetch('/api/TenantPortal/MyRequests');
                const result = await response.json();
                if (result.success) {
                    if (result.data.length === 0) {
                        container.innerHTML = '<div class="text-center py-3 text-muted x-small">Bạn chưa có yêu cầu nào.</div>';
                        return;
                    }
                    container.innerHTML = result.data.slice(0, 5).map(r => `
                        <div class="p-3 bg-light rounded-4 mb-3">
                            <div class="d-flex justify-content-between align-items-start mb-1">
                                <div class="fw-bold small">${r.title}</div>
                                <span class="status-pill status-${r.status.toLowerCase() === 'pending' ? 'locked' : 'active'}" style="font-size: 0.6rem;">${r.status}</span>
                            </div>
                            <div class="x-small text-muted">${new Date(r.createdAt).toLocaleString('vi-VN')}</div>
                        </div>
                    `).join('');
                }
            } catch (e) {}
        }

        async function submitRequest() {
            const form = document.getElementById('requestForm');
            const data = Object.fromEntries(new FormData(form).entries());
            if (!data.Title || !data.Description) {
                alert("Vui lòng nhập đầy đủ thông tin.");
                return;
            }

            try {
                const response = await fetch('/api/TenantPortal/CreateRequest', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                const result = await response.json();
                if (result.success) {
                    showPremiumToast("Thành công", "Yêu cầu của bạn đã được gửi tới quản lý.", "success");
                    form.reset();
                    loadRequests();
                } else {
                    alert(result.message);
                }
            } catch (e) {
                alert("Lỗi khi gửi yêu cầu.");
            }
        }
    </script>

    <style>
        .animate-fade-in { animation: fadeIn 0.4s ease-out; }
        @@keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    </style>
}
