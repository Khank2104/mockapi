@{
    ViewData["Title"] = "Dashboard";
}

<div class="container py-5">
    <!-- Header Section -->
    <div class="d-flex justify-content-between align-items-center mb-5 animate-slide-up">
        <div>
            <h1 class="fw-bold mb-1">Dashboard</h1>
            <p class="text-muted" id="welcomeText">Welcome back, loading...</p>
        </div>
        <div class="d-flex gap-3">
            <button id="addUserBtn" class="btn btn-primary-custom" style="display: none;" onclick="editUser()">
                <i class="bi bi-plus-lg"></i> Add New User
            </button>
            <button onclick="logout()" class="btn btn-outline-danger border-0 rounded-3">
                Sign Out
            </button>
        </div>
    </div>

    <!-- Admin Section: User List -->
    <div id="adminSection" class="animate-slide-up" style="display: none; animation-delay: 0.1s;">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div class="input-group" style="max-width: 300px;">
                <span class="input-group-text bg-white border-end-0"><i class="bi bi-search"></i></span>
                <input type="text" id="searchInput" class="form-control border-start-0" placeholder="Search users...">
            </div>
            <h5 class="mb-0 fw-bold"><i class="bi bi-people-fill me-2 text-primary"></i><span id="userCount">0 users</span></h5>
        </div>
        <div class="card-glass p-0 overflow-hidden">
            <div class="p-4 border-bottom border-secondary border-opacity-25 d-flex justify-content-between align-items-center">
                <h5 class="mb-0 fw-bold">System Users</h5>
                <span class="badge bg-primary rounded-pill" id="userCount">0 users</span>
            </div>
            <div class="table-responsive">
                <table class="user-table mb-0">
                    <thead>
                        <tr>
                            <th style="cursor: pointer" onclick="sortUsers('name')">Name <i class="bi bi-arrow-down-up small ms-1"></i></th>
                            <th style="cursor: pointer" onclick="sortUsers('role')">Role <i class="bi bi-arrow-down-up small ms-1"></i></th>
                            <th style="cursor: pointer" onclick="sortUsers('email')">Email <i class="bi bi-arrow-down-up small ms-1"></i></th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="userTableBody">
                        <!-- Dữ liệu sẽ được load ở đây -->
                        <tr>
                            <td colspan="4" class="text-center py-5" id="loadingRow">
                                <div class="spinner-border text-primary" role="status">
                                    <span class="visually-hidden">Loading...</span>
                                </div>
                                <div class="mt-2 text-muted small">Đang tải dữ liệu...</div>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- User Section: Professional Profile Dashboard -->
    <div id="userSection" class="animate-slide-up" style="display: none; animation-delay: 0.2s;">
        <div class="row g-4">
            <!-- Profile Info Card -->
            <div class="col-lg-4">
                <div class="card-glass h-100 p-0 overflow-hidden text-center">
                    <div style="height: 100px; background: var(--primary); opacity: 0.8;"></div>
                    <div style="margin-top: -50px;">
                        <img id="userAvatar" src="" class="avatar-img shadow-lg" style="width: 100px; height: 100px; border: 4px solid white;">
                    </div>
                    <div class="p-4">
                        <h3 id="userName" class="fw-bold mb-1"></h3>
                        <p id="userEmail" class="text-muted small mb-3"></p>
                        <span class="role-badge role-user">Verified Member</span>
                        
                        <div class="mt-4 pt-4 border-top border-secondary border-opacity-10 d-flex justify-content-around">
                            <div>
                                <div class="fw-bold">128</div>
                                <div class="text-muted x-small">Posts</div>
                            </div>
                            <div>
                                <div class="fw-bold">1.2k</div>
                                <div class="text-muted x-small">Followers</div>
                            </div>
                            <div>
                                <div class="fw-bold">342</div>
                                <div class="text-muted x-small">Following</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Stats & Activity -->
            <div class="col-lg-8">
                <!-- Quick Stats -->
                <div class="row g-3 mb-4">
                    <div class="col-md-4">
                        <div class="card-glass p-3 text-center">
                            <div class="text-primary fs-3 mb-1"><i class="bi bi-lightning-charge"></i></div>
                            <div class="h4 fw-bold mb-0">850</div>
                            <div class="text-muted small">Activity Points</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card-glass p-3 text-center">
                            <div class="text-success fs-3 mb-1"><i class="bi bi-calendar-check"></i></div>
                            <div class="h4 fw-bold mb-0">14</div>
                            <div class="text-muted small">Day Streak</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card-glass p-3 text-center">
                            <div class="text-warning fs-3 mb-1"><i class="bi bi-award"></i></div>
                            <div class="h4 fw-bold mb-0">Gold</div>
                            <div class="text-muted small">Membership Level</div>
                        </div>
                    </div>
                </div>

                <!-- Recent Activity Mockup -->
                <div class="card-glass">
                    <h5 class="fw-bold mb-4">Recent Activity</h5>
                    <div class="d-flex flex-column gap-3">
                        <div class="d-flex align-items-center gap-3 p-2 rounded-3 hover-effect">
                            <div class="bg-primary bg-opacity-10 p-2 rounded-circle text-primary"><i class="bi bi-pencil-square"></i></div>
                            <div class="flex-grow-1">
                                <div class="small fw-bold">Updated profile information</div>
                                <div class="text-muted x-small">2 hours ago</div>
                            </div>
                        </div>
                        <div class="d-flex align-items-center gap-3 p-2 rounded-3 hover-effect">
                            <div class="bg-success bg-opacity-10 p-2 rounded-circle text-success"><i class="bi bi-key"></i></div>
                            <div class="flex-grow-1">
                                <div class="small fw-bold">Password changed successfully</div>
                                <div class="text-muted x-small">Yesterday</div>
                            </div>
                        </div>
                        <div class="d-flex align-items-center gap-3 p-2 rounded-3 hover-effect">
                            <div class="bg-info bg-opacity-10 p-2 rounded-circle text-info"><i class="bi bi-box-arrow-in-right"></i></div>
                            <div class="flex-grow-1">
                                <div class="small fw-bold">New login from Chrome on Windows</div>
                                <div class="text-muted x-small">3 days ago</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- User Modal (Add/Edit) -->
<div class="modal fade" id="userModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content card-glass">
            <div class="modal-header border-0">
                <h5 class="modal-title fw-bold" id="modalTitle">Add User</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="userForm">
                    <input type="hidden" id="userId">
                    <div class="mb-3">
                        <label class="form-label small text-muted">Full Name</label>
                        <input type="text" id="editName" class="form-control form-control-custom" placeholder="Ví dụ: Nguyễn Văn A" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small text-muted">Username</label>
                        <input type="text" id="editUsername" class="form-control form-control-custom" placeholder="Ví dụ: van_a_99" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small text-muted">Role</label>
                        <select id="editRole" class="form-control form-control-custom">
                            <option value="user">User (Thành viên thường)</option>
                            <option value="admin">Admin (Quản trị viên)</option>
                            <option value="superuser">Superuser (Quản trị cấp cao)</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small text-muted">Password</label>
                        <input type="password" id="editPassword" class="form-control form-control-custom" placeholder="Nhập mật khẩu cho user mới">
                    </div>
                    <div class="mb-3">
                        <label class="form-label small text-muted">Email Address</label>
                        <input type="email" id="editEmail" class="form-control form-control-custom" placeholder="email@example.com" required>
                    </div>
                </form>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" onclick="saveUser()" class="btn btn-primary-custom" style="width: auto;">Save Changes</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/dashboard.js"></script>
}
