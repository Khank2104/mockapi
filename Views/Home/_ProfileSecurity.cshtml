<div class="animate-fade-in">
    <h3 class="profile-section-title"><i class="bi bi-shield-lock"></i> Bảo mật tài khoản</h3>
    
    <div class="glass-card bg-light bg-opacity-50 border-0 p-4 mb-4">
        <div class="d-flex align-items-center gap-3">
            <div class="bg-warning bg-opacity-10 text-warning p-3 rounded-circle">
                <i class="bi bi-key-fill fs-4"></i>
            </div>
            <div>
                <h4 class="fs-6 fw-bold mb-1">Đổi mật khẩu định kỳ</h4>
                <p class="text-muted small mb-0">Bạn nên thay đổi mật khẩu ít nhất 3 tháng một lần để bảo vệ tài khoản.</p>
            </div>
        </div>
    </div>

    <form id="security-form">
        <div class="row g-3">
            <div class="col-md-12">
                <div class="profile-input-group">
                    <label class="profile-label">Mật khẩu hiện tại</label>
                    <input type="password" id="sec-current-pw" class="form-control profile-input" placeholder="••••••••">
                </div>
            </div>
            <div class="col-md-6">
                <div class="profile-input-group">
                    <label class="profile-label">Mật khẩu mới</label>
                    <input type="password" id="sec-new-pw" class="form-control profile-input" placeholder="Tối thiểu 6 ký tự">
                </div>
            </div>
            <div class="col-md-6">
                <div class="profile-input-group">
                    <label class="profile-label">Xác nhận mật khẩu mới</label>
                    <input type="password" id="sec-confirm-pw" class="form-control profile-input" placeholder="Nhập lại mật khẩu mới">
                </div>
            </div>
        </div>
    </form>
    
    <div class="mt-4 pt-3 border-top">
        <button class="btn btn-dark px-5 py-3 rounded-pill shadow-lg" onclick="SecurityMgmt.changePassword()">
            <i class="bi bi-arrow-repeat me-2"></i> Cập nhật mật khẩu
        </button>
    </div>
</div>
