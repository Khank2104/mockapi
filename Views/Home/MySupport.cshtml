@{
    Layout = "_TenantLayout";
    ViewData["Title"] = "Hỗ trợ & Yêu cầu";
}

<div class="profile-container animate-fade-in">
    <div class="row g-4">
        <div class="col-lg-4">
            <div class="glass-card p-4 border-0 shadow-premium sticky-top" style="top: 100px; z-index: 10;">
                <div class="badge bg-primary bg-opacity-10 text-primary p-2 px-3 rounded-pill mb-3 border border-primary border-opacity-10">
                    <i class="bi bi-send-fill me-2"></i>Tạo yêu cầu mới
                </div>
                <h4 class="fw-bold mb-4 text-main">Bạn cần hỗ trợ?</h4>
                <form id="addRequestForm">
                    <div class="profile-input-group">
                        <label class="profile-label">Loại yêu cầu</label>
                        <select id="req-type" class="form-select profile-input border-0 shadow-none">
                            <option value="Repair">Sửa chữa thiết bị</option>
                            <option value="Complaint">Khiếu nại / Góp ý</option>
                            <option value="Security">An ninh / Trật tự</option>
                            <option value="Other">Khác</option>
                        </select>
                    </div>
                    <div class="profile-input-group">
                        <label class="profile-label">Tiêu đề</label>
                        <input type="text" id="req-title" class="form-control profile-input border-0 shadow-none" placeholder="VD: Hư vòi nước">
                    </div>
                    <div class="profile-input-group">
                        <label class="profile-label">Mô tả chi tiết</label>
                        <textarea id="req-desc" class="form-control profile-input border-0 shadow-none" rows="4" placeholder="Mô tả cụ thể vấn đề..."></textarea>
                    </div>
                    <button type="button" class="btn btn-premium w-100 py-3 rounded-4 shadow-premium mt-3 fw-bold" onclick="SupportMgmt.submitRequest()">
                        Gửi yêu cầu ngay
                    </button>
                </form>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="glass-card p-4 p-md-5 border-0 shadow-premium h-100">
                <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
                    <h5 class="fw-bold mb-0 text-main"><i class="bi bi-chat-left-text-fill me-2 text-warning"></i>Lịch sử yêu cầu</h5>
                    <div class="badge bg-secondary bg-opacity-10 text-secondary rounded-pill px-3 py-2 x-small fw-bold">
                        PHẢN HỒI: TRONG 24H
                    </div>
                </div>
                
                <div id="request-list-container" class="dashboard-list">
                    <!-- Requests populated by JS -->
                    <div class="text-center py-5">
                        <div class="spinner-border text-warning opacity-25 mb-3" role="status"></div>
                        <div class="x-small text-muted fw-medium">Đang tải lịch sử hỗ trợ...</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/modules/tenant/support.js" asp-append-version="true"></script>
}
