@{
    var role = User.FindFirst("role")?.Value?.ToLower();
    Layout = (role == "superuser" || role == "admin") ? "_AdminLayout" : "_TenantLayout";
    ViewData["Title"] = "Hồ sơ cá nhân";
}

@* CSS moved to premium-layout.css *@

<div class="profile-container animate-fade-in">
    <!-- Profile Header Card -->
    <div class="glass-card p-0 overflow-hidden mb-5 border-0 shadow-premium">
        <div class="premium-hero-banner" style="height: 120px; border-radius: 0;"></div>
        <div class="px-4 px-md-5 pb-4" style="margin-top: -50px;">
            <div class="d-flex flex-column flex-md-row align-items-center align-items-md-end gap-4 position-relative">
                <div class="profile-avatar-wrapper shadow-premium">
                    <img id="main-avatar-img" src="/img/default-avatar.png" class="profile-avatar-img" style="border: 5px solid var(--glass-bg);">
                    <label for="avatar-input" class="avatar-edit-badge">
                        <i class="bi bi-camera-fill"></i>
                    </label>
                    <input type="file" id="avatar-input" hidden accept="image/*" onchange="AccountInfo.uploadAvatar(this.files[0])">
                </div>
                <div class="flex-grow-1 text-center text-md-start pb-2">
                    <h2 class="fw-extrabold mb-1 text-main" id="header-name">---</h2>
                    <div class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3 py-2 fw-bold x-small uppercase">
                        <i class="bi bi-shield-check me-1"></i> <span id="header-role">---</span>
                    </div>
                </div>
                <div class="pb-2">
                    <div class="d-flex gap-2">
                        <div class="badge bg-secondary bg-opacity-10 text-secondary rounded-pill px-3 py-2 fw-bold small">
                            <i class="bi bi-calendar-check me-1"></i> Tham gia: <span id="header-join-date">01/2024</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Sidebar Navigation -->
        <div class="col-lg-3">
            <div class="glass-card p-3 shadow-premium border-0 sticky-top" style="top: 100px;">
                <h4 class="fs-7 fw-bold text-muted mb-3 px-3 text-uppercase letter-spacing-1">Cài đặt hồ sơ</h4>
                <nav class="nav flex-column gap-2">
                    <a class="profile-nav-link active rounded-4 d-flex align-items-center gap-3 p-3 text-decoration-none" href="#" data-tab="account">
                        <i class="bi bi-person-bounding-box fs-5"></i> <span class="fw-bold">Tài khoản</span>
                    </a>
                    @if (role == "tenant")
                    {
                        <a class="profile-nav-link rounded-4 d-flex align-items-center gap-3 p-3 text-decoration-none" href="#" data-tab="identity">
                            <i class="bi bi-card-text fs-5"></i> <span class="fw-bold">Cá nhân</span>
                        </a>
                    }
                    <a class="profile-nav-link rounded-4 d-flex align-items-center gap-3 p-3 text-decoration-none" href="#" data-tab="security">
                        <i class="bi bi-shield-lock fs-5"></i> <span class="fw-bold">Bảo mật</span>
                    </a>
                </nav>
            </div>
        </div>

        <!-- Main Content Area -->
        <div class="col-lg-9">
            <div class="glass-card shadow-premium border-0 p-4 p-md-5 h-100">
                <div id="tab-account" class="profile-tab-content">
                    @await Html.PartialAsync("_ProfileAccount")
                </div>
                @if (role == "tenant")
                {
                    <div id="tab-identity" class="profile-tab-content d-none">
                        @await Html.PartialAsync("_ProfileIdentity")
                    </div>
                }
                <div id="tab-security" class="profile-tab-content d-none">
                    @await Html.PartialAsync("_ProfileSecurity")
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/modules/tenant/profile.js" asp-append-version="true"></script>
}
