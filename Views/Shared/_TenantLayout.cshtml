<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Tenant Portal</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Outfit:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap-icons/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/glassmorphism.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/premium_dashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/tenants/tenant-portal.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/tenants/theme.css" asp-append-version="true" />
</head>
<body class="tenant-body">
    <script>
        (function() {
            const theme = localStorage.getItem('tenant-theme') || 'light';
            document.documentElement.setAttribute('data-theme', theme);
        })();
    </script>
    <div class="dashboard-wrapper">
        <!-- Sidebar -->
        <aside class="sidebar">
            <div class="sidebar-logo">
                <div class="logo-icon bg-primary bg-gradient">
                    <i class="bi bi-house-heart-fill"></i>
                </div>
                <span>Tenant Portal</span>
            </div>
            
            <nav class="sidebar-nav">
                <ul class="nav-list">
                    <li class="nav-item">
                        <a href="/" class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
                            <i class="bi bi-grid-1x2-fill"></i>
                            <span>Bảng điều khiển</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="/Home/MyRoom" class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "MyRoom" ? "active" : "")">
                            <i class="bi bi-door-closed-fill"></i>
                            <span>Phòng của tôi</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="/Home/MyInvoices" class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "MyInvoices" ? "active" : "")">
                            <i class="bi bi-receipt-cutoff"></i>
                            <span>Hóa đơn</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="/Home/MySupport" class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "MySupport" ? "active" : "")">
                            <i class="bi bi-chat-dots-fill"></i>
                            <span>Hỗ trợ & Yêu cầu</span>
                        </a>
                    </li>
                    <li class="nav-divider">TÀI KHOẢN</li>
                    <li class="nav-item">
                        <a href="/Home/Profile" class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Profile" ? "active" : "")">
                            <i class="bi bi-person-badge-fill"></i>
                            <span>Hồ sơ cá nhân</span>
                        </a>
                    </li>
                </ul>
            </nav>

            <div class="sidebar-footer">
                <a href="javascript:void(0)" onclick="logout()" class="nav-link text-danger">
                    <i class="bi bi-box-arrow-right"></i>
                    <span>Đăng xuất</span>
                </a>
            </div>
        </aside>

        <!-- Main Content -->
        <div class="main-content">
            <header class="top-header">
                <div class="welcome-text">
                    <h1 id="tenant-welcome" class="fw-bold">Chào mừng trở lại!</h1>
                    <p class="text-muted small mb-0">Hệ thống quản lý phòng trọ thông minh</p>
                </div>

                <div class="header-actions">
                    <div class="header-icon-btn" id="theme-btn" onclick="toggleTheme()" title="Chuyển chế độ sáng/tối">
                        <i class="bi bi-moon-stars"></i>
                    </div>
                    <div class="header-icon-btn" id="notification-bell" onclick="toggleNotificationModal()" title="Thông báo">
                        <i class="bi bi-bell"></i>
                        <span id="notification-count" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger d-none">
                            0
                        </span>
                    </div>

                    <div class="user-profile-badge" onclick="window.location.href='/Home/Profile'">
                        <img id="navAvatar" src="" class="avatar-sm" alt="Avatar">
                        <div class="user-info">
                            <span id="navUserName" class="name">Tenant</span>
                            <span class="role">Khách thuê</span>
                        </div>
                    </div>
                </div>
            </header>

            <div class="content-body p-4 p-md-5">
                @RenderBody()
            </div>
        </div>
    </div>

    <!-- Notification Modal -->
    <div class="modal fade" id="notificationListModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-sm-fixed-right">
            <div class="modal-content glass-card border-0 rounded-4 shadow-lg">
                <div class="modal-header border-0 pb-0">
                    <h5 class="fw-bold mb-0">Thông báo</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div id="notification-list" class="overflow-auto" style="max-height: 400px;">
                        <div class="text-center py-4 opacity-50">Đang tải...</div>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button class="btn btn-link text-decoration-none small" onclick="markAllNotificationsAsRead()">Đánh dấu đã đọc hết</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Toast Container -->
    <div class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 1100;">
        <div id="liveToast" class="toast align-items-center border-0 rounded-4 shadow-lg glass-card" role="alert" aria-live="assertive" aria-atomic="true" style="background: rgba(255, 255, 255, 0.9);">
            <div class="d-flex">
                <div class="toast-body d-flex align-items-center">
                    <i class="bi me-3 fs-4" id="toastIcon"></i>
                    <div>
                        <div class="fw-bold" id="toastTitle"></div>
                        <div id="toastMessage" class="small opacity-75"></div>
                    </div>
                </div>
                <button type="button" class="btn-close me-2 m-auto" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/signalr/signalr.min.js"></script>
    
    <script src="~/js/tenants/tenant-ui.js" asp-append-version="true"></script>
    <script src="~/js/tenants/tenant-notifications.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
