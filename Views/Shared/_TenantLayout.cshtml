<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - QuanTro Resident</title>
    
    <!-- Core Fonts & Icons -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    
    <!-- Centralized Theme System (The Heart) -->
    <link rel="stylesheet" href="~/css/core/theme-system.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/layouts/premium-layout.css" asp-append-version="true" />
</head>
<body>
    <script>
        (function() {
            const theme = localStorage.getItem('theme') || 'light';
            document.documentElement.setAttribute('data-theme', theme);
        })();
    </script>

    <div class="dashboard-wrapper">
        <!-- Sidebar Navigation -->
        <aside class="sidebar shadow-premium">
            <div class="sidebar-logo">
                <div class="stat-icon bg-white bg-opacity-10 text-white mb-0" style="width: 42px; height: 42px; border-radius: 12px; display: flex; align-items: center; justify-content: center;">
                    <i class="bi bi-house-heart-fill fs-4"></i>
                </div>
                <div class="ms-3">
                    <span class="fw-extrabold d-block lh-1" style="letter-spacing: -0.5px; font-size: 1.1rem; color: white;">QUAN TRỌ</span>
                    <span class="xx-small fw-bold uppercase opacity-50" style="color: rgba(255,255,255,0.7);">Resident Portal</span>
                </div>
            </div>

            <nav>
                <div class="nav-section-label">Menu chính</div>
                <ul class="list-unstyled px-2">
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")" href="/Home/Index">
                            <i class="bi bi-grid-1x2-fill"></i> <span>Tổng quan</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "MyRoom" ? "active" : "")" href="/Home/MyRoom">
                            <i class="bi bi-door-open-fill"></i> <span>Phòng của tôi</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "MyInvoices" ? "active" : "")" href="/Home/MyInvoices">
                            <i class="bi bi-receipt-cutoff"></i> <span>Hóa đơn</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "MySupport" ? "active" : "")" href="/Home/MySupport">
                            <i class="bi bi-chat-left-dots-fill"></i> <span>Yêu cầu hỗ trợ</span>
                        </a>
                    </li>
                </ul>

                <div class="nav-section-label mt-4">Tài khoản</div>
                <ul class="list-unstyled px-2">
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Profile" ? "active" : "")" href="/Home/Profile">
                            <i class="bi bi-person-badge-fill"></i> <span>Hồ sơ cá nhân</span>
                        </a>
                    </li>
                </ul>
            </nav>

            <div class="sidebar-footer mt-auto">
                <a href="javascript:void(0)" onclick="logout()" class="nav-link text-danger">
                    <i class="bi bi-box-arrow-right"></i> <span>Đăng xuất</span>
                </a>
            </div>
        </aside>

        <!-- Main Content Area -->
        <div class="main-content">
            <header class="top-header">
                <div class="d-flex align-items-center gap-3">
                    <button class="mobile-menu-btn d-lg-none" onclick="toggleSidebar()">
                        <i class="bi bi-list fs-4"></i>
                    </button>
                    <div class="welcome-text">
                        <h1 id="tenant-welcome">Chào mừng trở lại!</h1>
                        <p class="d-none d-sm-block">Hệ thống quản lý cư dân thông minh</p>
                    </div>
                </div>

                <div class="header-actions">
                    <button class="header-icon-btn" id="theme-btn" onclick="toggleTheme()" title="Chế độ sáng/tối">
                        <i class="bi bi-moon-stars"></i>
                    </button>
                    
                    <button class="header-icon-btn position-relative" onclick="toggleNotificationModal()">
                        <i class="bi bi-bell"></i>
                        <span id="notification-count" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger d-none">0</span>
                    </button>

                    <div class="user-profile-badge ms-2" onclick="window.location.href='/Home/Profile'">
                        <div id="navAvatarContainer" class="avatar-sm bg-primary text-white d-flex align-items-center justify-content-center fw-bold">
                            <span id="navInitial">U</span>
                        </div>
                        <div class="user-info d-none d-md-flex">
                            <span class="name" id="navUserName">Cư dân</span>
                            <span class="role">Khách thuê</span>
                        </div>
                    </div>
                </div>
            </header>

            <div class="dashboard-content animate-fade-in">
                @RenderBody()
            </div>
        </div>
    </div>

    <!-- Notification Modal -->
    <div class="modal fade" id="notificationListModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-sm-fixed-right">
            <div class="modal-content glass-card border-0 rounded-4 shadow-lg">
                <div class="modal-header border-0 pb-0">
                    <h5 class="fw-bold mb-0">Thông báo</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div id="notification-list" class="overflow-auto" style="max-height: 400px;">
                        <div class="text-center py-4 opacity-50">Đang tải...</div>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button class="btn btn-link text-decoration-none small" onclick="markAllNotificationsAsRead()">Đánh dấu đã đọc hết</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Toast Container -->
    <div class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 1100;">
        <div id="liveToast" class="toast align-items-center border-0 rounded-4 shadow-lg glass-card" role="alert" aria-live="assertive" aria-atomic="true" style="background: rgba(255, 255, 255, 0.9);">
            <div class="d-flex">
                <div class="toast-body d-flex align-items-center">
                    <i class="bi me-3 fs-4" id="toastIcon"></i>
                    <div>
                        <div class="fw-bold" id="toastTitle"></div>
                        <div id="toastMessage" class="small opacity-75"></div>
                    </div>
                </div>
                <button type="button" class="btn-close me-2 m-auto" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/signalr/signalr.min.js"></script>
    
    <script src="~/js/modules/tenant/tenant-ui.js" asp-append-version="true"></script>
    <script src="~/js/modules/tenant/tenant-notifications.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
