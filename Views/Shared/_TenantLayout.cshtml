<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - QuanTro Tenant</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Outfit:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/glassmorphism.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/premium_dashboard.css" asp-append-version="true" />
</head>
<body>
    <div class="dashboard-wrapper">
        <!-- Sidebar -->
        <aside class="sidebar" style="background: rgba(30, 41, 59, 0.95);">
            <div class="sidebar-logo">
                <i class="bi bi-house-heart-fill"></i>
                <span>Phòng Của Tôi</span>
            </div>
            
            <nav style="flex: 1;">
                <ul style="list-style: none;">
                    <li class="nav-item">
                        <a href="/" class="nav-link active">
                            <i class="bi bi-speedometer2"></i>
                            <span>Bảng điều khiển</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="/Home/Profile" class="nav-link">
                            <i class="bi bi-person-circle"></i>
                            <span>Hồ sơ cá nhân</span>
                        </a>
                    </li>
                </ul>
            </nav>

            <div class="sidebar-footer" style="padding-top: 2rem; border-top: 1px solid rgba(255,255,255,0.1);">
                <a href="javascript:void(0)" onclick="logout()" class="nav-link text-danger">
                    <i class="bi bi-box-arrow-right"></i>
                    <span>Đăng xuất</span>
                </a>
            </div>
        </aside>

        <!-- Main Content -->
        <div class="main-content">
            <header class="top-header">
                <div class="welcome-text">
                    <h1 id="tenant-welcome">Chào bạn!</h1>
                    <p class="text-muted small">Hôm nay bạn thế nào?</p>
                </div>

                <div class="header-actions d-flex align-items-center gap-3">
                    <div class="user-profile-widget">
                        <img id="navAvatar" src="" class="rounded-circle" style="width: 32px; height: 32px; object-fit: cover;">
                        <span id="navUserName" class="fw-bold small">Tenant</span>
                    </div>
                </div>
            </header>

            @RenderBody()
        </div>
    </div>

    <!-- Toast Container -->
    <div class="toast-container" id="toast-container"></div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    
    <script>
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/notificationHub")
            .build();

        connection.on("NewNotification", (userId) => {
            showPremiumToast("Thông báo", "Có tin mới cho bạn. Hãy tải lại trang để xem nhé!", "info");
        });

        connection.start().catch(err => console.error(err.toString()));

        function showPremiumToast(title, message, type = 'info') {
            const container = document.getElementById('toast-container');
            const toast = document.createElement('div');
            toast.className = `premium-toast`;
            toast.innerHTML = `
                <i class="bi bi-bell-fill text-primary"></i>
                <div>
                    <div class="fw-bold small">${title}</div>
                    <div class="x-small opacity-75">${message}</div>
                </div>
            `;
            container.appendChild(toast);
            setTimeout(() => {
                toast.style.opacity = '0';
                toast.style.transform = 'translateX(100%)';
                setTimeout(() => toast.remove(), 500);
            }, 5000);
        }

        function logout() {
            localStorage.removeItem('currentUser');
            window.location.href = '/Account/Login';
        }

        (function() {
            const userJson = localStorage.getItem('currentUser');
            if (userJson) {
                const user = JSON.parse(userJson);
                document.getElementById('navUserName').innerText = user.name;
                document.getElementById('navAvatar').src = user.avatar || `https://ui-avatars.com/api/?name=${encodeURIComponent(user.name)}&background=random`;
                document.getElementById('tenant-welcome').innerText = `Chào ${user.name}!`;
            } else {
                window.location.href = '/Account/Login';
            }
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
