<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - QuanTro Admin</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Outfit:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap-icons/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/core/theme-system.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components/glassmorphism.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/layouts/premium-layout.css" asp-append-version="true" />
    
    <script>
        // Apply theme immediately to prevent flash
        (function() {
            const savedTheme = localStorage.getItem('theme') || 'light';
            document.documentElement.setAttribute('data-theme', savedTheme);
        })();
    </script>
</head>
<body>
    <div class="dashboard-wrapper">
        <!-- Sidebar -->
        <aside class="sidebar">
            <div class="sidebar-logo">
                <div class="stat-icon bg-secondary bg-opacity-20 text-white mb-0" style="width: 40px; height: 40px;">
                    <i class="bi bi-shield-lock-fill"></i>
                </div>
                <span>QuanTro<span class="fw-light">Admin</span></span>
            </div>
            
            <nav>
                <ul style="list-style: none;">
                    <li class="nav-item">
                        <a href="javascript:void(0)" class="nav-link active" onclick="switchModule('overview', this)">
                            <i class="bi bi-grid-1x2-fill"></i>
                            <span>Tổng quan</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="javascript:void(0)" class="nav-link" onclick="switchModule('motels', this)">
                            <i class="bi bi-houses-fill"></i>
                            <span>Sơ đồ Phòng & Tầng</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="javascript:void(0)" class="nav-link" onclick="switchModule('tenants', this)">
                            <i class="bi bi-people-fill"></i>
                            <span>Khách thuê</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="javascript:void(0)" class="nav-link" onclick="switchModule('contracts', this)">
                            <i class="bi bi-file-earmark-text-fill"></i>
                            <span>Hợp đồng</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="javascript:void(0)" class="nav-link" onclick="switchModule('billing', this)">
                            <i class="bi bi-receipt"></i>
                            <span>Hóa đơn & Điện nước</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="javascript:void(0)" class="nav-link" onclick="switchModule('global-services', this)">
                            <i class="bi bi-gear-fill"></i>
                            <span>Cấu hình Điện/Nước</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="javascript:void(0)" class="nav-link" onclick="switchModule('requests', this)">
                            <i class="bi bi-chat-left-quote-fill"></i>
                            <span>Yêu cầu</span>
                            <span class="badge rounded-pill bg-danger ms-auto d-none" id="sidebarRequestBadge">0</span>
                        </a>
                    </li>
                    <li class="nav-item superuser-only d-none">
                        <a href="javascript:void(0)" class="nav-link" onclick="switchModule('admin-mgmt', this)">
                            <i class="bi bi-shield-lock-fill"></i>
                            <span>Quản trị Hệ thống</span>
                        </a>
                    </li>
                </ul>
            </nav>

            <div class="sidebar-footer" style="padding-top: 2rem; border-top: 1px solid rgba(255,255,255,0.1);">
                <a href="/Home/Profile" class="nav-link">
                    <i class="bi bi-person-circle"></i>
                    <span>Tài khoản</span>
                </a>
                <a href="/Settings" class="nav-link">
                    <i class="bi bi-gear-fill"></i>
                    <span>Cài đặt</span>
                </a>
                <a href="javascript:void(0)" onclick="logout()" class="nav-link text-danger">
                    <i class="bi bi-box-arrow-right"></i>
                    <span>Đăng xuất</span>
                </a>
            </div>
        </aside>

        <!-- Main Content -->
        <div class="main-content">
            <header class="top-header">
                <div class="welcome-text d-flex align-items-center gap-3">
                    <button class="mobile-menu-btn" onclick="toggleMobileMenu()">
                        <i class="bi bi-list fs-4"></i>
                    </button>
                    <div>
                        <h1 id="page-title" class="mb-1 fs-4">Xin chào!</h1>
                        <p class="text-muted x-small mb-0 d-none d-sm-block" id="dynamic-greeting">Chúc bạn một ngày làm việc hiệu quả.</p>
                    </div>
                </div>

                <div class="header-actions">
                    <div class="search-box d-none d-lg-flex align-items-center px-3 py-2 bg-secondary bg-opacity-10 rounded-pill border border-secondary border-opacity-10 shadow-sm">
                        <i class="bi bi-search text-muted me-2"></i>
                        <input type="text" class="border-0 bg-transparent small" placeholder="Tìm kiếm nhanh..." style="outline: none;">
                    </div>
                    
                    <div class="header-icon-btn" onclick="toggleTheme()" title="Đổi giao diện">
                        <i id="theme-icon" class="bi bi-moon-stars"></i>
                    </div>

                    <div class="header-icon-btn" onclick="toggleNotificationModal()" title="Thông báo">
                        <i class="bi bi-bell"></i>
                        <span id="notification-count" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger d-none">
                            0
                        </span>
                    </div>

                    <div class="user-profile-badge" onclick="window.location.href='/Home/Profile'">
                        <img id="navAvatar" src="" class="avatar-sm" alt="Admin Avatar">
                        <div class="user-info">
                            <div id="navUserName" class="name">Admin</div>
                            <div class="role">Quản trị viên</div>
                        </div>
                    </div>
                </div>
            </header>

            @RenderBody()
        </div>
    </div>

    <!-- Notification Modal -->
    <div class="modal fade" id="notificationListModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-sm-fixed-right" style="max-width: 400px;">
            <div class="modal-content glass-card border-0 rounded-4 shadow-lg">
                <div class="modal-header border-0 pb-0">
                    <h5 class="fw-bold mb-0">Thông báo hệ thống</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div id="notification-list" class="overflow-auto" style="max-height: 450px;">
                        <div class="text-center py-4 opacity-50">Đang tải...</div>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button class="btn btn-link text-decoration-none small text-primary" onclick="markAllNotificationsAsRead()">Đánh dấu đã đọc hết</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Toast Container -->
    <div class="toast-container" id="toast-container"></div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/chartjs/chart.min.js"></script>
    <script src="~/lib/signalr/signalr.min.js"></script>
    <script src="~/js/modules/admin/admin-core.js" asp-append-version="true"></script>
    <script src="~/js/modules/admin/admin-ui.js" asp-append-version="true"></script>
    <script src="~/js/modules/admin/admin-notifications.js" asp-append-version="true"></script>
    <script src="~/js/modules/admin/dashboard-charts.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
