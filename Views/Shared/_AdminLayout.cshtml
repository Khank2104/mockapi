<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - QuanTro Admin</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Outfit:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/glassmorphism.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/premium_dashboard.css" asp-append-version="true" />
    
    <script>
        // Apply theme immediately to prevent flash
        (function() {
            const savedTheme = localStorage.getItem('theme') || 'light';
            document.documentElement.setAttribute('data-theme', savedTheme);
        })();
    </script>
</head>
<body>
    <div class="dashboard-wrapper">
        <!-- Sidebar -->
        <aside class="sidebar">
            <div class="sidebar-logo">
                <div class="stat-icon bg-white bg-opacity-20 text-white mb-0" style="width: 40px; height: 40px;">
                    <i class="bi bi-shield-lock-fill"></i>
                </div>
                <span>QuanTro<span class="fw-light">Admin</span></span>
            </div>
            
            <nav style="flex: 1;">
                <ul style="list-style: none;">
                    <li class="nav-item">
                        <a href="javascript:void(0)" class="nav-link active" onclick="switchModule('overview', this)">
                            <i class="bi bi-grid-1x2-fill"></i>
                            <span>Tổng quan</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="javascript:void(0)" class="nav-link" onclick="switchModule('motels', this)">
                            <i class="bi bi-houses-fill"></i>
                            <span>Sơ đồ Phòng & Tầng</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="javascript:void(0)" class="nav-link" onclick="switchModule('tenants', this)">
                            <i class="bi bi-people-fill"></i>
                            <span>Khách thuê</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="javascript:void(0)" class="nav-link" onclick="switchModule('contracts', this)">
                            <i class="bi bi-file-earmark-text-fill"></i>
                            <span>Hợp đồng</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="javascript:void(0)" class="nav-link" onclick="switchModule('billing', this)">
                            <i class="bi bi-receipt"></i>
                            <span>Hóa đơn & Điện nước</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="javascript:void(0)" class="nav-link" onclick="switchModule('global-services', this)">
                            <i class="bi bi-gear-fill"></i>
                            <span>Cấu hình Điện/Nước</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="javascript:void(0)" class="nav-link" onclick="switchModule('requests', this)">
                            <i class="bi bi-chat-left-quote-fill"></i>
                            <span>Yêu cầu</span>
                            <span class="badge rounded-pill bg-danger ms-auto d-none" id="sidebarRequestBadge">0</span>
                        </a>
                    </li>
                    <li class="nav-item superuser-only d-none">
                        <a href="javascript:void(0)" class="nav-link" onclick="switchModule('admin-mgmt', this)">
                            <i class="bi bi-shield-lock-fill"></i>
                            <span>Quản trị Hệ thống</span>
                        </a>
                    </li>
                </ul>
            </nav>

            <div class="sidebar-footer" style="padding-top: 2rem; border-top: 1px solid rgba(255,255,255,0.1);">
                <a href="/Home/Profile" class="nav-link">
                    <i class="bi bi-person-circle"></i>
                    <span>Tài khoản</span>
                </a>
                <a href="javascript:void(0)" onclick="logout()" class="nav-link text-danger">
                    <i class="bi bi-box-arrow-right"></i>
                    <span>Đăng xuất</span>
                </a>
            </div>
        </aside>

        <!-- Main Content -->
        <div class="main-content">
            <header class="top-header">
                <div class="welcome-text d-flex align-items-center gap-3">
                    <button class="mobile-menu-btn" onclick="toggleMobileMenu()">
                        <i class="bi bi-list fs-4"></i>
                    </button>
                    <div>
                        <h1 id="page-title" class="mb-1 fs-4">Xin chào!</h1>
                        <p class="text-muted x-small mb-0 d-none d-sm-block" id="dynamic-greeting">Chúc bạn một ngày làm việc hiệu quả.</p>
                    </div>
                </div>

                <div class="header-actions d-flex align-items-center gap-4">
                    <div class="search-box d-none d-lg-flex align-items-center px-3 py-2 bg-white bg-opacity-50 rounded-pill border border-white">
                        <i class="bi bi-search text-muted me-2"></i>
                        <input type="text" class="border-0 bg-transparent small" placeholder="Tìm kiếm nhanh..." style="outline: none;">
                    </div>
                    
                    <div class="theme-toggle cursor-pointer bg-white bg-opacity-50 p-2 rounded-circle border border-white" onclick="toggleTheme()" title="Đổi giao diện">
                        <i id="theme-icon" class="bi bi-moon-stars fs-5 text-muted"></i>
                    </div>

                    <div class="position-relative cursor-pointer" onclick="toggleNotificationModal()">
                        <i class="bi bi-bell fs-5 text-muted"></i>
                        <span id="notification-count" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger d-none" style="font-size: 0.5rem; padding: 0.25em 0.4em;">
                            0
                        </span>
                    </div>

                    <div class="user-profile-widget px-3 py-2">
                        <div>
                            <div id="navUserName" class="fw-bold small lh-1 mb-1">Admin</div>
                            <div class="text-muted" style="font-size: 0.65rem;">Quản trị viên</div>
                        </div>
                    </div>
                </div>
            </header>

            @RenderBody()
        </div>
    </div>

    <!-- Notification Modal -->
    <div class="modal fade" id="notificationListModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-sm-fixed-right" style="max-width: 400px;">
            <div class="modal-content glass-card border-0 rounded-4 shadow-lg">
                <div class="modal-header border-0 pb-0">
                    <h5 class="fw-bold mb-0">Thông báo hệ thống</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div id="notification-list" class="overflow-auto" style="max-height: 450px;">
                        <div class="text-center py-4 opacity-50">Đang tải...</div>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button class="btn btn-link text-decoration-none small text-primary" onclick="markAllNotificationsAsRead()">Đánh dấu đã đọc hết</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Toast Container -->
    <div class="toast-container" id="toast-container"></div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script src="~/js/admin/admin-core.js" asp-append-version="true"></script>
    <script src="~/js/dashboard-charts.js" asp-append-version="true"></script>
    
    <script>
        function toggleTheme() {
            const html = document.documentElement;
            const currentTheme = html.getAttribute('data-theme');
            const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
            
            html.setAttribute('data-theme', newTheme);
            localStorage.setItem('theme', newTheme);
            updateThemeIcon(newTheme);
        }

        function updateThemeIcon(theme) {
            const icon = document.getElementById('theme-icon');
            if (icon) {
                icon.className = theme === 'dark' ? 'bi bi-sun fs-5 text-warning' : 'bi bi-moon-stars fs-5 text-muted';
            }
        }

        // Initialize icon on load
        document.addEventListener('DOMContentLoaded', () => {
            updateThemeIcon(document.documentElement.getAttribute('data-theme'));
        });
    </script>
    
    <script>
        function toggleMobileMenu() {
            document.querySelector('.sidebar').classList.toggle('active');
        }

        // Intercept switchModule to close sidebar on mobile
        const baseSwitchModule = window.switchModule;
        window.switchModule = function(id, el) {
            if (typeof baseSwitchModule === 'function') baseSwitchModule(id, el);
            if (window.innerWidth <= 768) {
                const sidebar = document.querySelector('.sidebar');
                if (sidebar) sidebar.classList.remove('active');
            }
        }
    </script>
    
    <script>
        // SignalR Initialization
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/notificationHub")
            .build();

        connection.on("NewNotification", (userId) => {
            showPremiumToast("Thông báo mới", "Bạn có một thông báo mới trong hệ thống.", "info");
            if (typeof loadRecentRequests === 'function') loadRecentRequests();
        });

        connection.start().catch(err => console.error(err.toString()));

        document.addEventListener('DOMContentLoaded', () => {
            loadNotificationsCount();
        });

        async function loadNotificationsCount() {
            try {
                const res = await fetch('/api/NotificationProxy/GetMyNotifications');
                const result = await res.json();
                if (result.success) {
                    const count = result.unreadCount;
                    const badge = document.getElementById('notification-count');
                    if (count > 0) {
                        badge.innerText = count > 99 ? '99+' : count;
                        badge.classList.remove('d-none');
                    } else {
                        badge.classList.add('d-none');
                    }
                }
            } catch (e) {}
        }

        async function toggleNotificationModal() {
            const modal = new bootstrap.Modal(document.getElementById('notificationListModal'));
            modal.show();
            
            const list = document.getElementById('notification-list');
            try {
                const res = await fetch('/api/NotificationProxy/GetMyNotifications');
                const result = await res.json();
                if (result.success) {
                    if (result.data.length === 0) {
                        list.innerHTML = '<div class="text-center py-4 opacity-50">Không có thông báo nào.</div>';
                    } else {
                        list.innerHTML = result.data.map(n => `
                            <div class="p-3 mb-2 rounded-3 ${n.isRead ? 'bg-light opacity-75' : 'bg-primary bg-opacity-10 border-start border-primary border-4'}" 
                                 onclick="markNotificationAsRead(${n.id}, this)" style="cursor: pointer;">
                                <div class="d-flex justify-content-between align-items-start mb-1">
                                    <span class="fw-bold small">${n.title}</span>
                                    <span class="x-small text-muted">${new Date(n.createdAt).toLocaleDateString('vi-VN')}</span>
                                </div>
                                <div class="small text-muted">${n.message}</div>
                            </div>
                        `).join('');
                    }
                }
            } catch (e) {
                list.innerHTML = '<div class="alert alert-danger">Lỗi tải thông báo.</div>';
            }
        }

        async function markNotificationAsRead(id, element) {
            try {
                const res = await fetch(`/api/NotificationProxy/MarkAsRead/${id}`, { method: 'POST' });
                const result = await res.json();
                if (result.success) {
                    element.classList.remove('bg-primary', 'bg-opacity-10', 'border-start', 'border-primary', 'border-4');
                    element.classList.add('bg-light', 'opacity-75');
                    loadNotificationsCount();
                }
            } catch (e) {}
        }

        async function markAllNotificationsAsRead() {
            try {
                const res = await fetch('/api/NotificationProxy/MarkAllAsRead', { method: 'POST' });
                const result = await res.json();
                if (result.success) {
                    const items = document.querySelectorAll('#notification-list > div');
                    items.forEach(el => {
                        el.classList.remove('bg-primary', 'bg-opacity-10', 'border-start', 'border-primary', 'border-4');
                        el.classList.add('bg-light', 'opacity-75');
                    });
                    loadNotificationsCount();
                }
            } catch (e) {}
        }

        function showPremiumToast(title, message, type = 'info') {
            const container = document.getElementById('toast-container');
            const toast = document.createElement('div');
            toast.className = `premium-toast`;
            toast.innerHTML = `
                <i class="bi bi-bell-fill text-primary"></i>
                <div>
                    <div class="fw-bold small">${title}</div>
                    <div class="x-small opacity-75">${message}</div>
                </div>
            `;
            container.appendChild(toast);
            setTimeout(() => {
                toast.style.opacity = '0';
                toast.style.transform = 'translateX(100%)';
                setTimeout(() => toast.remove(), 500);
            }, 5000);
        }

        async function logout() {
            try {
                await fetch('/api/UserProxy/Logout', { method: 'POST' });
            } catch (e) {
                console.error("Logout API failed", e);
            }
            localStorage.removeItem('currentUser');
            window.location.href = '/Account/Login';
        }

        // Auth Check & Greeting Logic
        (function() {
            const hour = new Date().getHours();
            const greetingEl = document.getElementById('dynamic-greeting');
            const now = new Date();
            const options = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' };
            const dateStr = now.toLocaleDateString('vi-VN', options);
            
            let message = "Chào buổi sáng";
            if (hour >= 12 && hour < 18) message = "Chào buổi chiều";
            if (hour >= 18) message = "Chào buổi tối";
            
            greetingEl.innerText = `${message}, hôm nay là ${dateStr}`;

            const userJson = localStorage.getItem('currentUser');
            if (userJson) {
                const user = JSON.parse(userJson);
                document.getElementById('navUserName').innerText = user.name;
                document.getElementById('navAvatar').src = user.avatar || `https://ui-avatars.com/api/?name=${encodeURIComponent(user.name)}&background=6366f1&color=fff`;
                
                if (user.role && user.role.toLowerCase() === 'superuser') {
                    document.querySelectorAll('.superuser-only').forEach(el => el.classList.remove('d-none'));
                }
            } else {
                window.location.href = '/Account/Login';
            }
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
