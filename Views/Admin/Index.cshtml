@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Dashboard Tổng quan";
}

<div id="module-container">
    <!-- Overview Module -->
    <section id="module-overview" class="module-section animate-fade-in">
        <div class="stats-grid">
            <div class="glass-card">
                <div class="stat-icon" style="background: rgba(99, 102, 241, 0.1); color: #6366f1;">
                    <i class="bi bi-door-open-fill"></i>
                </div>
                <div class="stat-value" id="stat-total-rooms">0</div>
                <div class="stat-label">Tổng số phòng</div>
            </div>
            <div class="glass-card">
                <div class="stat-icon" style="background: rgba(34, 197, 94, 0.1); color: #22c55e;">
                    <i class="bi bi-person-check-fill"></i>
                </div>
                <div class="stat-value" id="stat-occupied-rooms">0</div>
                <div class="stat-label">Phòng đang ở</div>
            </div>
            <div class="glass-card">
                <div class="stat-icon" style="background: rgba(245, 158, 11, 0.1); color: #f59e0b;">
                    <i class="bi bi-currency-dollar"></i>
                </div>
                <div class="stat-value" id="stat-revenue">0đ</div>
                <div class="stat-label">Doanh thu dự kiến (T4)</div>
            </div>
            <div class="glass-card">
                <div class="stat-icon" style="background: rgba(239, 68, 68, 0.1); color: #ef4444;">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                </div>
                <div class="stat-value" id="stat-requests">0</div>
                <div class="stat-label">Yêu cầu chờ xử lý</div>
            </div>
        </div>

        <div class="row g-4 mt-2">
            <div class="col-lg-8">
                <div class="glass-card">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h3 class="fw-bold fs-5">Yêu cầu hỗ trợ gần đây</h3>
                        <button class="btn btn-premium btn-sm" onclick="switchModule('requests')">Xem tất cả</button>
                    </div>
                    <div class="table-container">
                        <table class="premium-table">
                            <thead>
                                <tr>
                                    <th>PHÒNG</th>
                                    <th>TIÊU ĐỀ</th>
                                    <th>TRẠNG THÁI</th>
                                    <th>THỜI GIAN</th>
                                </tr>
                            </thead>
                            <tbody id="recent-requests-list">
                                <!-- Loading placeholder -->
                                <tr><td colspan="4" class="text-center py-5 text-muted">Đang tải dữ liệu...</td></tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="glass-card">
                    <h3 class="fw-bold fs-5 mb-4">Tỷ lệ lấp đầy</h3>
                    <div style="position: relative; height: 250px;">
                        <canvas id="occupancyChart"></canvas>
                    </div>
                    <div class="mt-4">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="small text-muted"><i class="bi bi-circle-fill me-2" style="color: #6366f1;"></i> Đang ở</span>
                            <span class="fw-bold" id="label-occupied">0</span>
                        </div>
                        <div class="d-flex justify-content-between">
                            <span class="small text-muted"><i class="bi bi-circle-fill me-2" style="color: #e2e8f0;"></i> Trống</span>
                            <span class="fw-bold" id="label-vacant">0</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Motel Module -->
    <section id="module-motels" class="module-section d-none">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold fs-4">Quản lý Khu trọ & Phòng</h2>
            <button class="btn btn-premium" onclick="showAddMotelModal()">
                <i class="bi bi-plus-lg"></i>
                <span>Thêm khu trọ</span>
            </button>
        </div>
        <div id="motel-list-container" class="row g-4">
            <!-- Content will be loaded via JS -->
        </div>
    </section>

    <!-- Motel Details Module (Deep Management) -->
    <section id="module-room-details" class="module-section d-none">
        <div class="d-flex align-items-center gap-3 mb-4">
            <button class="btn btn-sm btn-outline-secondary rounded-circle" onclick="switchModule('motels')">
                <i class="bi bi-arrow-left"></i>
            </button>
            <h2 class="fw-bold fs-4 mb-0">Quản lý chi tiết: <span id="detail-room-code" class="text-primary">---</span></h2>
        </div>

        <div class="row g-4">
            <!-- Left: Room Settings -->
            <div class="col-lg-6">
                <div class="glass-card h-100">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h3 class="fw-bold fs-5 mb-0"><i class="bi bi-gear-fill me-2"></i>Cấu hình thuê</h3>
                        <button class="btn btn-sm btn-premium px-3" onclick="saveRoomSettings()">Lưu cấu hình</button>
                    </div>
                    <form id="roomSettingsForm" class="row g-3">
                        <input type="hidden" name="RoomId" id="settings-roomId">
                        <div class="col-md-6">
                            <label class="form-label small fw-bold opacity-75">GIÁ THUÊ CƠ BẢN</label>
                            <input type="number" name="BaseRent" class="form-control">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold opacity-75">TIỀN CỌC</label>
                            <input type="number" name="DepositAmount" class="form-control">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold opacity-75">SỐ NGƯỜI TIÊU CHUẨN</label>
                            <input type="number" name="StandardOccupants" class="form-control">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold opacity-75">PHỤ THU NGƯỜI THÊM</label>
                            <input type="number" name="ExtraOccupantFee" class="form-control">
                        </div>
                        <div class="col-12 mt-3">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" name="ApplyExtraOccupantFee" id="applyExtraFee">
                                <label class="form-check-label small fw-bold" for="applyExtraFee">Áp dụng phụ thu khi vượt số người</label>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Right: Service Pricing -->
            <div class="col-lg-6">
                <div class="glass-card h-100">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h3 class="fw-bold fs-5 mb-0"><i class="bi bi-lightning-charge-fill me-2"></i>Phí dịch vụ</h3>
                        <button class="btn btn-sm btn-premium px-3" onclick="saveServiceSettings()">Cập nhật giá</button>
                    </div>
                    <div id="room-services-list" class="vstack gap-3">
                        <!-- Services will be loaded here -->
                        <div class="text-center py-4 text-muted">Đang tải cấu hình dịch vụ...</div>
                    </div>
                </div>
            </div>

            <!-- Bottom: Occupants Management -->
            <div class="col-12">
                <div class="glass-card">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h3 class="fw-bold fs-5 mb-0"><i class="bi bi-people-fill me-2"></i>Thành viên trong phòng</h3>
                        <button class="btn btn-sm btn-outline-primary px-3 rounded-pill" onclick="showAddOccupantModal()">
                            <i class="bi bi-plus-lg"></i> Thêm người ở
                        </button>
                    </div>
                    <div class="table-container">
                        <table class="premium-table">
                            <thead>
                                <tr>
                                    <th>HỌ TÊN</th>
                                    <th>QUAN HỆ</th>
                                    <th>NGÀY VÀO</th>
                                    <th>SỐ ĐIỆN THOẠI</th>
                                    <th>HÀNH ĐỘNG</th>
                                </tr>
                            </thead>
                            <tbody id="occupants-list-container">
                                <tr><td colspan="5" class="text-center py-4 text-muted">Chưa có thành viên nào.</td></tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Tenants Module -->
    <section id="module-tenants" class="module-section d-none">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold fs-4">Danh sách Khách thuê</h2>
            <button class="btn btn-premium" onclick="showAddTenantModal()">
                <i class="bi bi-person-plus-fill"></i>
                <span>Thêm khách thuê</span>
            </button>
        </div>
        <div class="glass-card">
            <div class="mb-4">
                <input type="text" class="form-control" placeholder="Tìm kiếm theo tên, CCCD hoặc SĐT..." style="border-radius: 12px; padding: 0.75rem 1.25rem;">
            </div>
            <div class="table-container">
                <table class="premium-table">
                    <thead>
                        <tr>
                            <th>HỌ TÊN</th>
                            <th>PHÒNG</th>
                            <th>LIÊN HỆ</th>
                            <th>TRẠNG THÁI</th>
                            <th>THAO TÁC</th>
                        </tr>
                    </thead>
                    <tbody id="tenant-list-container">
                        <tr><td colspan="5" class="text-center py-5 text-muted">Đang tải...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </section>

    <!-- Billing Module -->
    <section id="module-billing" class="module-section d-none">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold fs-4">Điện nước & Hóa đơn</h2>
            <div class="d-flex gap-2">
                <select class="form-select" id="billing-month" style="width: 120px; border-radius: 10px;">
                    @for (int i = 1; i <= 12; i++) {
                        <option value="@i" selected="@(DateTime.Now.Month == i)">Tháng @i</option>
                    }
                </select>
                <select class="form-select" id="billing-year" style="width: 100px; border-radius: 10px;">
                    <option value="@DateTime.Now.Year">@DateTime.Now.Year</option>
                </select>
                <button class="btn btn-premium" onclick="loadBillingData()">
                    <i class="bi bi-arrow-clockwise"></i>
                </button>
            </div>
        </div>
        <div class="glass-card">
            <div class="table-container">
                <table class="premium-table">
                    <thead>
                        <tr>
                            <th>PHÒNG</th>
                            <th>CHỈ SỐ ĐIỆN</th>
                            <th>CHỈ SỐ NƯỚC</th>
                            <th>HÓA ĐƠN</th>
                            <th>THAO TÁC</th>
                        </tr>
                    </thead>
                    <tbody id="billing-list-container">
                        <tr><td colspan="5" class="text-center py-5 text-muted">Vui lòng tải dữ liệu...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </section>

    <!-- Requests Module -->
    <section id="module-requests" class="module-section d-none">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold fs-4">Yêu cầu từ khách thuê</h2>
        </div>
        <div class="glass-card">
            <div class="table-container">
                <table class="premium-table">
                    <thead>
                        <tr>
                            <th>PHÒNG</th>
                            <th>YÊU CẦU</th>
                            <th>LOẠI</th>
                            <th>TRẠNG THÁI</th>
                            <th>THỜI GIAN</th>
                            <th>HÀNH ĐỘNG</th>
                        </tr>
                    </thead>
                    <tbody id="all-requests-list-container">
                        <tr><td colspan="6" class="text-center py-5 text-muted">Đang tải...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </section>

    <!-- Superuser: Admin Management Module -->
    <section id="module-admin-mgmt" class="module-section d-none">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold fs-4">Quản trị Hệ thống (Admins)</h2>
            <button class="btn btn-premium" onclick="showAddAdminModal()">
                <i class="bi bi-person-plus-fill"></i> Thêm Admin mới
            </button>
        </div>
        <div class="glass-card">
            <div class="table-container">
                <table class="premium-table">
                    <thead>
                        <tr>
                            <th>HỌ TÊN</th>
                            <th>TÀI KHOẢN</th>
                            <th>TRẠNG THÁI</th>
                            <th>HÀNH ĐỘNG</th>
                        </tr>
                    </thead>
                    <tbody id="admin-list-container">
                        <tr><td colspan="4" class="text-center py-5 text-muted">Đang tải...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </section>
</div>

<!-- MODALS -->

<!-- Modal: Record Meter -->
<div class="modal fade" id="recordMeterModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content glass-card border-0 p-3">
            <div class="modal-header border-0">
                <h5 class="fw-bold mb-0">Ghi chỉ số - <span id="meterRoomCode"></span></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="recordMeterForm">
                    <input type="hidden" name="RoomId" id="meterRoomId">
                    <div class="mb-3">
                        <label class="form-label small fw-bold opacity-75">CHỈ SỐ ĐIỆN MỚI</label>
                        <input type="number" name="ElectricityReading" class="form-control" required placeholder="Nhập số điện...">
                    </div>
                    <div class="mb-4">
                        <label class="form-label small fw-bold opacity-75">CHỈ SỐ NƯỚC MỚI</label>
                        <input type="number" name="WaterReading" class="form-control" required placeholder="Nhập số nước...">
                    </div>
                    <button type="button" class="btn btn-premium w-100 py-3" onclick="submitMeterReading()">
                        Lưu chỉ số & Gửi thông báo
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Modal: Add Tenant & Contract -->
<div class="modal fade" id="addTenantModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content glass-card border-0 p-3">
            <div class="modal-header border-0">
                <h5 class="fw-bold mb-0">Thêm Khách thuê & Hợp đồng mới</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="addTenantForm">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label small fw-bold opacity-75">HỌ VÀ TÊN</label>
                            <input type="text" name="Name" class="form-control" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold opacity-75">SỐ ĐIỆN THOẠI</label>
                            <input type="text" name="PhoneNumber" class="form-control" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold opacity-75">USERNAME (Để đăng nhập)</label>
                            <input type="text" name="Username" class="form-control" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold opacity-75">EMAIL</label>
                            <input type="email" name="Email" class="form-control" required>
                        </div>
                        <hr class="my-4 opacity-10">
                        <div class="col-md-6">
                            <label class="form-label small fw-bold opacity-75">CHỌN PHÒNG</label>
                            <select name="RoomId" id="tenantRoomSelect" class="form-select" required>
                                <option value="">Đang tải phòng trống...</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold opacity-75">TIỀN THUÊ / THÁNG</label>
                            <input type="number" name="MonthlyRent" class="form-control" required>
                        </div>
                    </div>
                    <button type="button" class="btn btn-premium w-100 py-3 mt-4" onclick="submitAddTenant()">
                        Tạo tài khoản & Ký hợp đồng
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Modal: Add Admin (Superuser Only) -->
<div class="modal fade" id="addAdminModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content glass-card border-0 p-3">
            <div class="modal-header border-0">
                <h5 class="fw-bold mb-0">Thêm Quản trị viên (Admin)</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="addAdminForm">
                    <div class="mb-3">
                        <label class="form-label small fw-bold opacity-75">HỌ VÀ TÊN</label>
                        <input type="text" name="Name" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold opacity-75">TÊN ĐĂNG NHẬP</label>
                        <input type="text" name="Username" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold opacity-75">EMAIL</label>
                        <input type="email" name="Email" class="form-control" required>
                    </div>
                    <div class="mb-4 text-muted small">
                        <i class="bi bi-info-circle me-1"></i> Mật khẩu mặc định sẽ được gửi qua email hoặc đặt là 123456 (theo cấu hình hệ thống).
                    </div>
                    <button type="button" class="btn btn-premium w-100 py-3" onclick="submitAddAdmin()">
                        Tạo tài khoản Admin
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Modal: Add Motel -->
<div class="modal fade" id="addMotelModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content glass-card border-0 p-3">
            <div class="modal-header border-0">
                <h5 class="fw-bold mb-0">Thêm Khu trọ mới</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="addMotelForm">
                    <div class="mb-3">
                        <label class="form-label small fw-bold opacity-75">TÊN KHU TRỌ</label>
                        <input type="text" name="MotelName" class="form-control" required placeholder="Ví dụ: Nhà trọ Sắc Màu">
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold opacity-75">ĐỊA CHỈ</label>
                        <input type="text" name="Address" class="form-control" required placeholder="Địa chỉ chi tiết...">
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold opacity-75">MÔ TẢ</label>
                        <textarea name="Description" class="form-control" rows="2" placeholder="Thông tin thêm..."></textarea>
                    </div>
                    <div class="form-check form-switch mb-4">
                        <input class="form-check-input" type="checkbox" name="UseFloorManagement" checked id="useFloors">
                        <label class="form-check-label small fw-bold" for="useFloors">Sử dụng quản lý theo Tầng</label>
                    </div>
                    <button type="button" class="btn btn-premium w-100 py-3" onclick="submitAddMotel()">
                        Khởi tạo Khu trọ
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Data Loading Logic
        async function loadTenantsData() {
            const container = document.getElementById('tenant-list-container');
            try {
                const response = await fetch('/api/TenantManagement/GetAllTenants');
                const result = await response.json();
                if (result.success) {
                    if (result.data.length === 0) {
                        container.innerHTML = '<tr><td colspan="5" class="text-center py-5">Chưa có khách thuê nào.</td></tr>';
                        return;
                    }
                    container.innerHTML = result.data.map(t => `
                        <tr>
                            <td>
                                <div class="fw-bold">${t.name}</div>
                                <div class="x-small text-muted">CCCD: ${t.idCard || 'N/A'}</div>
                            </td>
                            <td><span class="fw-bold">Phòng ${t.currentRoomCode || 'N/A'}</span></td>
                            <td>
                                <div class="small"><i class="bi bi-phone me-1"></i>${t.phone}</div>
                                <div class="x-small text-muted"><i class="bi bi-envelope me-1"></i>${t.email || 'N/A'}</div>
                            </td>
                            <td><span class="status-pill status-active">${t.status}</span></td>
                            <td>
                                <button class="btn btn-sm btn-outline-primary rounded-pill">Chi tiết</button>
                            </td>
                        </tr>
                    `).join('');
                }
            } catch (e) {}
        }

        async function loadBillingData() {
            const container = document.getElementById('billing-list-container');
            const month = document.getElementById('billing-month').value;
            const year = document.getElementById('billing-year').value;
            
            try {
                const response = await fetch('/api/MotelManagement/MyMotels');
                const result = await response.json();
                if (result.success) {
                    let rooms = [];
                    result.data.forEach(m => {
                        m.floors.forEach(f => {
                            f.rooms.forEach(r => {
                                if (r.status === 'Occupied') rooms.push(r);
                            });
                        });
                    });

                    if (rooms.length === 0) {
                        container.innerHTML = '<tr><td colspan="5" class="text-center py-5">Không có phòng nào đang ở để ghi hóa đơn.</td></tr>';
                        return;
                    }

                    container.innerHTML = rooms.map(r => `
                        <tr>
                            <td><span class="fw-bold">Phòng ${r.roomCode}</span></td>
                            <td id="elec-${r.roomId}">--</td>
                            <td id="water-${r.roomId}">--</td>
                            <td id="inv-${r.roomId}"><span class="badge bg-light text-muted">Chưa chốt</span></td>
                            <td>
                                <button class="btn btn-sm btn-premium rounded-pill" onclick="showRecordMeterModal(${r.roomId}, '${r.roomCode}')">Ghi chỉ số</button>
                            </td>
                        </tr>
                    `).join('');
                }
            } catch (e) {}
        }

        async function loadAllRequestsData() {
            const container = document.getElementById('all-requests-list-container');
            try {
                const response = await fetch('/api/Request/GetAllRequests');
                const result = await response.json();
                if (result.success) {
                    if (result.data.length === 0) {
                        container.innerHTML = '<tr><td colspan="6" class="text-center py-5">Không có yêu cầu nào.</td></tr>';
                        return;
                    }
                    container.innerHTML = result.data.map(r => `
                        <tr>
                            <td><span class="fw-bold">Phòng ${r.roomId}</span></td>
                            <td>${r.title}</td>
                            <td><span class="badge bg-light text-dark">${r.requestType}</span></td>
                            <td><span class="status-pill status-${r.status.toLowerCase() === 'pending' ? 'locked' : 'active'}">${r.status}</span></td>
                            <td class="text-muted small">${new Date(r.createdAt).toLocaleString('vi-VN')}</td>
                            <td>
                                <button class="btn btn-sm btn-outline-primary rounded-pill" onclick="showHandleRequestModal(${r.requestId}, '${r.title}')">Xử lý</button>
                            </td>
                        </tr>
                    `).join('');
                }
            } catch (e) {}
        }

        async function loadAdminsData() {
            const container = document.getElementById('admin-list-container');
