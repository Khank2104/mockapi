@{
    ViewData["Title"] = "Admin Dashboard (Migration)";
}

<div class="container-fluid py-5 px-lg-5">
    <!-- Header Section -->
    <div class="d-flex justify-content-between align-items-end mb-4 animate-fade-in">
        <div>
            <h2 class="fw-bold mb-1">Quản lý hệ thống</h2>
            <p class="text-muted small mb-0" id="welcomeText">Đang tải...</p>
        </div>
        <div class="d-flex gap-2">
            <button id="addUserBtn" class="btn btn-secondary px-4" disabled>
                <i class="bi bi-person-x-fill me-2"></i>Tính năng đã chuyển dời
            </button>
        </div>
    </div>

    <!-- Stats Cards (Simplified for Phase 2) -->
    <div class="row g-4 mb-5 animate-fade-in" style="animation-delay: 0.1s;">
        <div class="col-md-4">
            <div class="stat-card">
                <div class="stat-icon bg-primary-light text-primary">
                    <i class="bi bi-shield-lock-fill"></i>
                </div>
                <h6 class="text-muted small fw-bold text-uppercase">Phân hệ mới</h6>
                <h3 class="fw-bold mb-0">Admin Mgmt</h3>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card">
                <div class="stat-icon" style="background: #ecfdf5; color: #10b981;">
                    <i class="bi bi-people-fill"></i>
                </div>
                <h6 class="text-muted small fw-bold text-uppercase">Phân hệ mới</h6>
                <h3 class="fw-bold mb-0">Tenant Mgmt</h3>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card">
                <div class="stat-icon" style="background: #fffbeb; color: #f59e0b;">
                    <i class="bi bi-house-door-fill"></i>
                </div>
                <h6 class="text-muted small fw-bold text-uppercase">Phân hệ mới</h6>
                <h3 class="fw-bold mb-0">Motel Mgmt</h3>
            </div>
        </div>
    </div>

    <!-- Info Section -->
    <div id="adminSection" class="animate-fade-in" style="animation-delay: 0.2s;">
        <div class="card-glass border-0 shadow-sm p-5 text-center">
             <i class="bi bi-cone-striped text-warning display-1 mb-4"></i>
             <h3 class="fw-bold">Giao diện cũ đang được nâng cấp</h3>
             <p class="text-muted mx-auto" style="max-width: 600px;">
                 Hệ thống quản lý user cũ đã được thay thế bằng các phân hệ nghiệp vụ Phòng trọ chuyên sâu trong Phase 2. 
                 Vui lòng truy cập các endpoint API chuyên biệt (`/api/AdminManagement`, `/api/TenantManagement`, `/api/MotelManagement`) 
                 hoặc sử dụng các View nghiệp vụ mới (nếu đã triển khai).
             </p>
             <div class="mt-4">
                 <a href="/" class="btn btn-primary-custom px-4">Quay lại Trang chủ</a>
             </div>
        </div>
    </div>
</div>

<div class="table-responsive d-none">
    <table id="userTableBody"></table>
</div>

@section Scripts {
    <script src="~/js/admin_dashboard.js"></script>
}
