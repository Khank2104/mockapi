@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Dashboard Tổng quan";
}

<div id="module-container">
    <style>
        /* Đảm bảo chữ trong các form nhập liệu luôn hiển thị rõ ràng trên nền sáng */
        .glass-card .form-control,
        .glass-card .form-select,
        .glass-card .form-label {
            color: #1e293b !important;
            font-weight: 500;
        }
        .glass-card .form-control::placeholder {
            color: #94a3b8 !important;
            opacity: 1;
        }
    </style>
    <!-- Overview Module -->
    <section id="module-overview" class="module-section animate-fade-in">
        <div class="stats-grid">
            <div class="glass-card border-start border-primary border-4">
                <div class="d-flex justify-content-between">
                    <div>
                        <div class="stat-label mb-1">Tổng số phòng</div>
                        <div class="stat-value text-primary" id="stat-total-rooms">0</div>
                    </div>
                    <div class="stat-icon bg-primary bg-opacity-10 text-primary">
                        <i class="bi bi-door-open-fill"></i>
                    </div>
                </div>
                <div class="mt-3 x-small text-muted">
                    <i class="bi bi-graph-up-arrow text-success me-1"></i> <span class="fw-bold text-success">+2</span> so với tháng trước
                </div>
            </div>
            <div class="glass-card border-start border-success border-4">
                <div class="d-flex justify-content-between">
                    <div>
                        <div class="stat-label mb-1">Phòng đang ở</div>
                        <div class="stat-value text-success" id="stat-occupied-rooms">0</div>
                    </div>
                    <div class="stat-icon bg-success bg-opacity-10 text-success">
                        <i class="bi bi-person-check-fill"></i>
                    </div>
                </div>
                <div class="mt-3 x-small text-muted">
                    Tỷ lệ lấp đầy: <span class="fw-bold" id="label-occupancy-rate">0%</span>
                </div>
            </div>
            <div class="glass-card border-start border-warning border-4">
                <div class="d-flex justify-content-between">
                    <div>
                        <div class="stat-label mb-1">Doanh thu dự kiến</div>
                        <div class="stat-value text-warning" id="stat-revenue">0đ</div>
                    </div>
                    <div class="stat-icon bg-warning bg-opacity-10 text-warning">
                        <i class="bi bi-wallet2"></i>
                    </div>
                </div>
                <div class="mt-3 x-small text-muted">
                    Kỳ thanh toán: <span class="fw-bold">Tháng @DateTime.Now.Month</span>
                </div>
            </div>
            <div class="glass-card border-start border-danger border-4">
                <div class="d-flex justify-content-between">
                    <div>
                        <div class="stat-label mb-1">Yêu cầu chờ xử lý</div>
                        <div class="stat-value text-danger" id="stat-requests">0</div>
                    </div>
                    <div class="stat-icon bg-danger bg-opacity-10 text-danger">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                    </div>
                </div>
                <div class="mt-3 x-small text-muted text-danger fw-bold">
                    Cần xử lý ngay!
                </div>
            </div>
        </div>

        <div class="row g-4 mt-2">
            <div class="col-lg-8">
                <div class="glass-card">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h3 class="fw-bold fs-5">Yêu cầu hỗ trợ gần đây</h3>
                        <button class="btn btn-premium btn-sm" onclick="switchModule('requests')">Xem tất cả</button>
                    </div>
                    <div class="table-container">
                        <table class="premium-table">
                            <thead>
                                <tr>
                                    <th>PHÒNG</th>
                                    <th>TIÊU ĐỀ</th>
                                    <th>TRẠNG THÁI</th>
                                    <th>THỜI GIAN</th>
                                </tr>
                            </thead>
                            <tbody id="recent-requests-list">
                                <!-- Loading placeholder with Skeleton -->
                                <tr><td colspan="4"><div class="skeleton" style="height: 40px; margin-bottom: 8px;"></div></td></tr>
                                <tr><td colspan="4"><div class="skeleton" style="height: 40px;"></div></td></tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="glass-card">
                    <h3 class="fw-bold fs-5 mb-4">Tỷ lệ lấp đầy</h3>
                    <div style="position: relative; height: 250px;">
                        <canvas id="occupancyChart"></canvas>
                    </div>
                    <div class="mt-4">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="small text-muted"><i class="bi bi-circle-fill me-2" style="color: #6366f1;"></i> Đang ở</span>
                            <span class="fw-bold" id="label-occupied">0</span>
                        </div>
                        <div class="d-flex justify-content-between">
                            <span class="small text-muted"><i class="bi bi-circle-fill me-2" style="color: #e2e8f0;"></i> Trống</span>
                            <span class="fw-bold" id="label-vacant">0</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Floor Map Module -->
    <section id="module-motels" class="module-section d-none">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="fw-bold fs-4 mb-1">Sơ đồ Phòng & Tầng</h2>
                <p class="text-muted small mb-0">Click vào phòng để xem chi tiết và cấu hình dịch vụ</p>
            </div>
            <div class="d-flex gap-2">
                <select id="floormap-motel-select" class="form-select rounded-4" onchange="loadFloormapForMotel()" style="min-width:200px">
                    <option value="">-- Chọn khu trọ --</option>
                </select>
                <button class="btn btn-premium" onclick="showAddMotelModal()">
                    <i class="bi bi-plus-lg"></i> <span class="d-none d-md-inline">Thêm khu trọ</span>
                </button>
            </div>
        </div>
        <!-- Floor Tabs + Room Grid -->
        <div id="floormap-container">
            <div class="text-center py-5 text-muted">
                <i class="bi bi-houses fs-1 d-block mb-3 opacity-25"></i>
                <p>Chọn khu trọ để xem sơ đồ</p>
            </div>
        </div>
        <!-- Room Detail Side Panel -->
        <div id="floormap-room-panel" class="d-none mt-4">
            <div class="glass-card">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h4 class="fw-bold mb-1"><i class="bi bi-door-open-fill me-2 text-primary"></i>Chi tiết Phòng: <span id="fmp-room-code" class="text-primary"></span></h4>
                        <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3" id="fmp-room-status">Trống</span>
                    </div>
                    <button class="btn btn-sm btn-outline-secondary rounded-pill px-3" onclick="closeFmpPanel()">
                        <i class="bi bi-x-lg me-1"></i> Đóng
                    </button>
                </div>
                <div class="row g-4">
                    <!-- Left: Financial Info (Read-only) -->
                    <div class="col-lg-4">
                        <h6 class="fw-bold text-muted small mb-3"><i class="bi bi-cash-stack me-2"></i>THÔNG TIN TÀI CHÍNH</h6>
                        <div class="vstack gap-3" id="fmp-finance-info">
                            <div class="d-flex justify-content-between align-items-center p-3 rounded-4 bg-light border">
                                <span class="small fw-bold">Giá thuê / tháng</span>
                                <span class="fw-bold text-primary" id="fmp-rent">--</span>
                            </div>
                            <div class="d-flex justify-content-between align-items-center p-3 rounded-4 bg-light border">
                                <span class="small fw-bold">Tiền cọ</span>
                                <span class="fw-bold" id="fmp-deposit">--</span>
                            </div>
                            <div class="d-flex justify-content-between align-items-center p-3 rounded-4 bg-light border">
                                <span class="small fw-bold">Số người tiêu chuẩn</span>
                                <span class="fw-bold" id="fmp-occupants">--</span>
                            </div>
                            <div class="d-flex justify-content-between align-items-center p-3 rounded-4 bg-light border">
                                <span class="small fw-bold">Phụ thu người thêm</span>
                                <span class="fw-bold" id="fmp-extra-fee">--</span>
                            </div>
                        </div>
                    </div>
                    <!-- Right: Services Checklist -->
                    <div class="col-lg-8">
                        <h6 class="fw-bold text-muted small mb-3"><i class="bi bi-lightning-charge-fill me-2"></i>DỊCH VỤ ÁP DỤNG CHO PHÒNG</h6>
                        <div class="alert alert-info border-0 bg-info bg-opacity-10 rounded-4 small mb-3">
                            <i class="bi bi-info-circle me-2"></i>
                            Dịch vụ <strong>bắt buộc</strong> (Biểu giá hệ thống) không thể bỏ. Dịch vụ tùy chọn có thể bật/tắt.
                        </div>
                        <div id="fmp-services-list" class="vstack gap-2">
                            <div class="text-center py-3 text-muted small">Đang tải dịch vụ...</div>
                        </div>
                        <div class="mt-3 d-none" id="fmp-save-row">
                            <button class="btn btn-premium w-100" onclick="saveFmpServices()">
                                <i class="bi bi-check2-circle me-2"></i>Lưu cấu hình Dịch vụ
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Global Services Configuration Module -->
    <section id="module-global-services" class="module-section d-none">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="fw-bold fs-4 mb-1">Cấu hình Dịch vụ Toàn hệ thống</h2>
                <p class="text-muted small mb-0">Thiết lập đơn giá mặc định áp dụng cho tất cả các phòng và gửi thông báo thay đổi.</p>
            </div>
            <div class="d-flex gap-2">
                <button class="btn btn-outline-primary shadow-sm px-4 rounded-pill" onclick="initializeDefaultServices()">
                    <i class="bi bi-magic me-2"></i> Khởi tạo mẫu
                </button>
                <button class="btn btn-outline-success shadow-sm px-4 rounded-pill" onclick="showAddGlobalServiceModal()">
                    <i class="bi bi-plus-lg me-2"></i> Thêm dịch vụ mới
                </button>
                <button class="btn btn-premium shadow-premium px-4" onclick="saveAllGlobalSettings()" id="btnSaveGlobalSettings">
                    <i class="bi bi-save2-fill me-2"></i> 
                    <span class="btn-text">Lưu cấu hình toàn bộ</span>
                    <span class="spinner-border spinner-border-sm d-none" role="status"></span>
                </button>
            </div>
        </div>
        
        <div class="row g-4">
            <div class="col-lg-8">
                <div class="glass-card">
                    <h3 class="fw-bold fs-5 mb-4 text-primary"><i class="bi bi-lightning-charge-fill me-2"></i>Thiết lập đơn giá mặc định</h3>
                    <p class="text-muted small mb-4">Lưu ý: Khi bạn lưu tại đây, hệ thống sẽ tự động cập nhật đơn giá cho tất cả các phòng và gửi thông báo đến từng khách thuê.</p>
                    
                    <form id="globalSettingsForm">
                        <div id="global-settings-fields">
                            <!-- Fields will be dynamically loaded here -->
                            <div class="text-center py-5">
                                <div class="spinner-border text-primary" role="status"></div>
                                <p class="mt-2 text-muted">Đang tải cấu hình hiện tại...</p>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
            
            <div class="col-lg-4">
                <div class="glass-card bg-primary bg-opacity-10 border-primary border-opacity-20">
                    <h3 class="fw-bold fs-5 mb-3"><i class="bi bi-info-circle-fill me-2"></i>Hướng dẫn</h3>
                    <ul class="small text-secondary ps-3">
                        <li class="mb-2"><strong>Đơn giá Điện:</strong> Tính theo số kWh tiêu thụ thực tế.</li>
                        <li class="mb-2"><strong>Đơn giá Nước:</strong> Tính theo số m3 tiêu thụ thực tế.</li>
                        <li class="mb-2"><strong>Phí dịch vụ:</strong> Các phí cố định hàng tháng (Rác, Wifi...).</li>
                        <li>Bấm <strong>"Lưu cấu hình"</strong> để áp dụng ngay lập tức cho toàn bộ hệ thống.</li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <!-- Modal: Edit Global Service -->
    <div class="modal fade" id="editGlobalServiceModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content glass-card border-0 p-3 overflow-hidden">
                <div class="modal-header border-0 pb-0">
                    <div>
                        <h5 class="fw-bold mb-1">Thiết lập đơn giá: <span id="edit-service-name" class="text-primary"></span></h5>
                        <p class="text-muted x-small mb-0">Mức giá này sẽ được áp dụng cho tất cả các phòng và gửi thông báo đến khách thuê.</p>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body pt-4">
                    <form id="editGlobalServiceForm">
                        <input type="hidden" id="edit-service-id" name="ServiceId">
                        <div class="mb-4">
                            <label class="form-label small fw-bold opacity-75">ĐƠN GIÁ MỚI (VNĐ / Đơn vị)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-end-0 rounded-start-4">
                                    <i class="bi bi-currency-dollar text-primary"></i>
                                </span>
                                <input type="number" id="edit-service-price" class="form-control border-start-0 rounded-end-4 py-3 fw-bold" placeholder="Nhập đơn giá..." required>
                            </div>
                        </div>
                        
                        <div class="alert alert-warning border-0 bg-warning bg-opacity-10 d-flex gap-3 mb-4 rounded-4">
                            <i class="bi bi-info-circle-fill text-warning fs-4"></i>
                            <div class="small text-dark-emphasis">
                                <strong>Lưu ý:</strong> Khi bạn cập nhật, hệ thống sẽ tự động gửi thông báo đến tất cả khách thuê để họ biết mức giá mới này.
                            </div>
                        </div>

                        <button type="button" id="btnSubmitGlobalService" class="btn btn-premium w-100 py-3 shadow-premium" onclick="submitEditGlobalService()">
                            <span class="btn-text">Cập nhật và Thông báo</span>
                            <span class="spinner-border spinner-border-sm d-none" role="status" aria-hidden="true"></span>
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal: Record Meter Reading -->
    <div class="modal fade" id="recordMeterModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content glass-card border-0 p-3 overflow-hidden">
                <div class="modal-header border-0 pb-0">
                    <div>
                        <h5 class="fw-bold mb-1">Ghi chỉ số: <span id="record-room-code" class="text-primary"></span></h5>
                        <p class="text-muted x-small mb-0">Nhập chỉ số điện/nước thực tế cho kỳ thanh toán hiện tại.</p>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body pt-4">
                    <form id="recordMeterForm">
                        <input type="hidden" id="record-roomId">
                        
                        <div class="row g-4 mb-4">
                            <!-- Điện -->
                            <div class="col-md-6">
                                <div class="p-3 bg-light rounded-4 h-100">
                                    <h6 class="fw-bold text-warning mb-3"><i class="bi bi-lightning-charge-fill me-2"></i>Chỉ số Điện</h6>
                                    <input type="hidden" id="record-elec-serviceId">
                                    <div class="mb-3">
                                        <label class="form-label x-small fw-bold opacity-75">SỐ CŨ</label>
                                        <input type="number" id="record-elec-prev" class="form-control rounded-3 py-2 bg-white" readonly>
                                    </div>
                                    <div>
                                        <label class="form-label x-small fw-bold opacity-75 text-primary">SỐ MỚI</label>
                                        <input type="number" id="record-elec-curr" class="form-control rounded-3 py-2 border-primary shadow-sm fw-bold" placeholder="Nhập số điện..." oninput="calculateElecUsage()">
                                    </div>
                                    <div class="mt-2 text-end text-muted x-small d-none" id="usage-elec-container">Tiêu thụ: <b id="usage-elec-value" class="text-dark">0</b> <span id="usage-elec-unit">kWh</span></div>
                                </div>
                            </div>
                            
                            <!-- Nước -->
                            <div class="col-md-6">
                                <div class="p-3 bg-light rounded-4 h-100">
                                    <h6 class="fw-bold text-info mb-3"><i class="bi bi-droplet-fill me-2"></i>Chỉ số Nước</h6>
                                    <input type="hidden" id="record-water-serviceId">
                                    <div class="mb-3">
                                        <label class="form-label x-small fw-bold opacity-75">SỐ CŨ</label>
                                        <input type="number" id="record-water-prev" class="form-control rounded-3 py-2 bg-white" readonly>
                                    </div>
                                    <div>
                                        <label class="form-label x-small fw-bold opacity-75 text-primary">SỐ MỚI</label>
                                        <input type="number" id="record-water-curr" class="form-control rounded-3 py-2 border-primary shadow-sm fw-bold" placeholder="Nhập số nước..." oninput="calculateWaterUsage()">
                                    </div>
                                    <div class="mt-2 text-end text-muted x-small d-none" id="usage-water-container">Tiêu thụ: <b id="usage-water-value" class="text-dark">0</b> <span id="usage-water-unit">Khối</span></div>
                                </div>
                            </div>
                        </div>

                        <button type="button" id="btnSubmitReading" class="btn btn-premium w-100 py-3 shadow-premium" onclick="submitMeterReading()">
                            <span class="btn-text">Lưu chỉ số điện & nước</span>
                            <span class="spinner-border spinner-border-sm d-none" role="status" aria-hidden="true"></span>
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
    <section id="module-motel-setup" class="module-section d-none">
        <div class="d-flex align-items-center gap-3 mb-4">
            <button class="btn btn-sm btn-outline-secondary rounded-circle" onclick="switchModule('motels')">
                <i class="bi bi-arrow-left"></i>
            </button>
            <h2 class="fw-bold fs-4 mb-0">Thiết lập Khu trọ: <span id="setup-motel-name" class="text-primary">---</span></h2>
        </div>

        <div class="row g-4">
            <div class="col-lg-4" id="setup-floor-card">
                <div class="glass-card h-100">
                    <h3 class="fw-bold fs-5 mb-3"><i class="bi bi-layers-fill me-2"></i>Khai báo Tầng</h3>
                    <form id="setupFloorForm">
                        <input type="hidden" id="setup-motelId" name="MotelId">
                        <div class="mb-3">
                            <label class="form-label">Tên tầng (VD: Tầng 1)</label>
                            <input type="text" class="form-control" name="FloorName" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Số thứ tự tầng (1, 2...)</label>
                            <input type="number" class="form-control" name="FloorNumber" required>
                        </div>
                        <button type="button" class="btn btn-premium w-100" onclick="submitSetupFloor()">Thêm Tầng</button>
                    </form>
                </div>
            </div>
            
            <div class="col-lg-8" id="setup-room-card">
                <div class="glass-card h-100">
                    <h3 class="fw-bold fs-5 mb-3"><i class="bi bi-door-open-fill me-2"></i>Khai báo Phòng</h3>
                    <form id="setupRoomForm" class="row g-3">
                        <input type="hidden" id="setup-room-motelId" name="MotelId">
                        <div class="col-md-6" id="setup-floor-select-container">
                            <label class="form-label">Thuộc Tầng</label>
                            <select class="form-select" name="FloorId" id="setup-floor-select">
                                <option value="">Đang tải...</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Mã phòng (VD: 101)</label>
                            <input type="text" class="form-control" name="RoomCode" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Diện tích (m2)</label>
                            <input type="number" class="form-control" name="Area" required>
                        </div>
                        <div class="col-12 mt-3">
                            <button type="button" class="btn btn-premium" onclick="submitSetupRoom()">Thêm Phòng</button>
                        </div>
                    </form>
                    
                    <hr class="my-4">
                    <h4 class="fw-bold fs-6 mb-3">Danh sách phòng</h4>
                    <div class="table-container">
                        <table class="premium-table">
                            <thead>
                                <tr>
                                    <th>TẦNG</th>
                                    <th>MÃ PHÒNG</th>
                                    <th>DIỆN TÍCH</th>
                                    <th>THAO TÁC</th>
                                </tr>
                            </thead>
                            <tbody id="setup-rooms-list">
                                <tr><td colspan="4" class="text-center py-3 text-muted">Chưa có phòng nào.</td></tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Motel Details Module (Deep Management) -->
    <section id="module-room-details" class="module-section d-none">
        <div class="d-flex align-items-center gap-3 mb-4">
            <button class="btn btn-sm btn-outline-secondary rounded-circle" onclick="switchModule('motels')">
                <i class="bi bi-arrow-left"></i>
            </button>
            <h2 class="fw-bold fs-4 mb-0">Quản lý chi tiết: <span id="detail-room-code" class="text-primary">---</span></h2>
        </div>

        <div class="row g-4">
            <!-- Left: Room Settings -->
            <div class="col-lg-6">
                <div class="glass-card h-100">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h3 class="fw-bold fs-5 mb-0"><i class="bi bi-gear-fill me-2"></i>Cấu hình thuê</h3>
                        <button class="btn btn-sm btn-premium px-3" onclick="saveRoomSettings()">Lưu cấu hình</button>
                    </div>
                    <form id="roomSettingsForm" class="row g-3">
                        <input type="hidden" name="RoomId" id="settings-roomId">
