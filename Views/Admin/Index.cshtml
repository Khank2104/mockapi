            } else {
                floorCard.classList.remove('d-none');
                roomCard.classList.remove('col-lg-12');
                roomCard.classList.add('col-lg-8');
                floorSelectContainer.classList.remove('d-none');
                loadSetupFloors(motelId);
            }
            
            loadSetupRooms(motelId);
