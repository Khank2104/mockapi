        async function showAddTenantModal() {
            const select = document.getElementById('tenantRoomSelect');
            select.innerHTML = '<option value="">Đang tải...</option>';
            
            new bootstrap.Modal(document.getElementById('addTenantModal')).show();

            // Fetch Vacant Rooms
            try {
                const response = await fetch('/api/MotelManagement/MyMotels');
                const result = await response.json();
                if (result.success) {
                    let vacantRooms = [];
                    result.data.forEach(m => {
                        m.floors.forEach(f => {
                            f.rooms.forEach(r => {
                                if (r.status === 'Vacant') {
                                    vacantRooms.push({ id: r.roomId, code: `${m.motelName} - ${r.roomCode}` });
                                }
                            });
                        });
                    });

                    if (vacantRooms.length === 0) {
                        select.innerHTML = '<option value="">Không còn phòng trống</option>';
                    } else {
                        select.innerHTML = vacantRooms.map(v => `<option value="${v.id}">${v.code}</option>`).join('');
                    }
                }
            } catch (e) {
                select.innerHTML = '<option value="">Lỗi tải dữ liệu</option>';
            }
        }

        async function submitAddTenant() {
            const form = document.getElementById('addTenantForm');
            const data = Object.fromEntries(new FormData(form).entries());
            
            try {
                // Step 1: Create Tenant Account & Contract
                const response = await fetch('/api/TenantManagement/CreateTenant', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        name: data.Name,
                        username: data.Username,
                        email: data.Email,
                        phoneNumber: data.PhoneNumber,
                        roomId: parseInt(data.RoomId),
                        monthlyRent: parseFloat(data.MonthlyRent)
                    })
                });
                const result = await response.json();
                if (result.success) {
                    showPremiumToast("Thành công", "Đã tạo tài khoản và hợp đồng mới.", "success");
                    bootstrap.Modal.getInstance(document.getElementById('addTenantModal')).hide();
                    loadTenantsData();
                } else {
                    alert(result.message);
                }
            } catch (e) {
                alert("Lỗi khi gửi dữ liệu.");
            }
        }

        function showAddAdminModal() {
            new bootstrap.Modal(document.getElementById('addAdminModal')).show();
        }

