                            <td>
                                <button class="btn btn-sm btn-outline-danger rounded-pill" onclick="toggleAdminStatus(${a.userId}, ${a.isActive})">
                                    ${a.isActive ? 'Khóa' : 'Mở khóa'}
                                </button>
                            </td>
                        </tr>
                    `).join('');
                }
            } catch (e) {}
        }

        // --- Modal Handlers ---

        function showRecordMeterModal(roomId, roomCode) {
            document.getElementById('meterRoomId').value = roomId;
            document.getElementById('meterRoomCode').innerText = roomCode;
            new bootstrap.Modal(document.getElementById('recordMeterModal')).show();
