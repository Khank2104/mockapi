@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container py-5">
    <!-- Header Section -->
    <div class="d-flex justify-content-between align-items-center mb-5 animate-slide-up">
        <div>
            <h1 class="fw-bold mb-1">Admin Dashboard</h1>
            <p class="text-muted" id="welcomeText">Welcome back, loading...</p>
        </div>
        <div class="d-flex gap-3">
            <button id="addUserBtn" class="btn btn-primary-custom" onclick="editUser()">
                <i class="bi bi-plus-lg"></i> Add New User
            </button>
            <button onclick="logout()" class="btn btn-outline-danger border-0 rounded-3">
                Sign Out
            </button>
        </div>
    </div>

    <!-- Admin Section: User List -->
    <div id="adminSection" class="animate-slide-up" style="animation-delay: 0.1s;">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div class="input-group" style="max-width: 300px;">
                <span class="input-group-text bg-white border-end-0"><i class="bi bi-search"></i></span>
                <input type="text" id="searchInput" class="form-control border-start-0" placeholder="Search users...">
            </div>
            <h5 class="mb-0 fw-bold"><i class="bi bi-people-fill me-2 text-primary"></i><span id="userCount">0 users</span></h5>
        </div>
        <div class="card-glass p-0 overflow-hidden">
            <div class="p-4 border-bottom border-secondary border-opacity-25 d-flex justify-content-between align-items-center">
                <h5 class="mb-0 fw-bold">System Users</h5>
                <span class="badge bg-primary rounded-pill" id="userCountBadge">0 users</span>
            </div>
            <div class="table-responsive">
                <table class="user-table mb-0">
                    <thead>
                        <tr>
                            <th style="cursor: pointer" onclick="sortUsers('name')">Name <i class="bi bi-arrow-down-up small ms-1"></i></th>
                            <th style="cursor: pointer" onclick="sortUsers('role')">Role <i class="bi bi-arrow-down-up small ms-1"></i></th>
                            <th style="cursor: pointer" onclick="sortUsers('email')">Email <i class="bi bi-arrow-down-up small ms-1"></i></th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="userTableBody">
                        <!-- Data will be loaded here -->
                        <tr>
                            <td colspan="4" class="text-center py-5" id="loadingRow">
                                <div class="spinner-border text-primary" role="status">
                                    <span class="visually-hidden">Loading...</span>
                                </div>
                                <div class="mt-2 text-muted small">Đang tải dữ liệu...</div>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Template cho dòng người dùng (Dùng để tách giao diện khỏi JS) -->
<template id="userRowTemplate">
    <tr>
        <td>
            <div class="d-flex align-items-center gap-3">
                <img src="" class="avatar-img user-avatar">
                <div>
                    <div class="fw-bold user-name"></div>
                    <div class="text-muted small user-username"></div>
                </div>
            </div>
        </td>
        <td><span class="role-badge"></span></td>
        <td class="user-email"></td>
        <td>
            <div class="d-flex gap-2">
                <button class="btn btn-sm btn-outline-primary border-0 btn-edit" title="Edit User"><i class="bi bi-pencil-fill"></i></button>
                <button class="btn btn-sm btn-outline-danger border-0 btn-delete" title="Delete User"><i class="bi bi-trash-fill"></i></button>
            </div>
        </td>
    </tr>
</template>

<!-- User Modal (Add/Edit) -->
<div class="modal fade" id="userModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content card-glass">
            <div class="modal-header border-0">
                <h5 class="modal-title fw-bold" id="modalTitle">Add User</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="userForm">
                    <input type="hidden" id="userId">
                    <div class="mb-3">
                        <label class="form-label small text-muted">Full Name</label>
                        <input type="text" id="editName" class="form-control form-control-custom" placeholder="Ví dụ: Nguyễn Văn A" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small text-muted">Username</label>
                        <input type="text" id="editUsername" class="form-control form-control-custom" placeholder="Ví dụ: van_a_99" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small text-muted">Role</label>
                        <select id="editRole" class="form-control form-control-custom">
                            <option value="user">User (Thành viên thường)</option>
                            <option value="admin">Admin (Quản trị viên)</option>
                            <option value="superuser">Superuser (Quản trị cấp cao)</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small text-muted">Password</label>
                        <input type="password" id="editPassword" class="form-control form-control-custom" placeholder="Nhập mật khẩu cho user mới">
                    </div>
                    <div class="mb-3">
                        <label class="form-label small text-muted">Email Address</label>
                        <input type="email" id="editEmail" class="form-control form-control-custom" placeholder="email@example.com" required>
                    </div>
                </form>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" onclick="saveUser()" class="btn btn-primary-custom" style="width: auto;">Save Changes</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/admin_dashboard.js"></script>
}
