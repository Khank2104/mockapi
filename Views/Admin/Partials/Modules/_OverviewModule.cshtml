<!-- Overview Module -->
<section id="module-overview" class="module-section animate-fade-in">
    <div class="stats-grid">
        <div class="glass-card border-start border-primary border-4">
            <div class="d-flex justify-content-between">
                <div>
                    <div class="stat-label mb-1">Tổng số phòng</div>
                    <div class="stat-value text-primary" id="stat-total-rooms">0</div>
                </div>
                <div class="stat-icon bg-primary bg-opacity-10 text-primary">
                    <i class="bi bi-door-open-fill"></i>
                </div>
            </div>
            <div class="mt-3 x-small text-muted">
                <i class="bi bi-graph-up-arrow text-success me-1"></i> <span class="fw-bold text-success">+2</span> so với tháng trước
            </div>
        </div>
        <div class="glass-card border-start border-success border-4">
            <div class="d-flex justify-content-between">
                <div>
                    <div class="stat-label mb-1">Phòng đang ở</div>
                    <div class="stat-value text-success" id="stat-occupied-rooms">0</div>
                </div>
                <div class="stat-icon bg-success bg-opacity-10 text-success">
                    <i class="bi bi-person-check-fill"></i>
                </div>
            </div>
            <div class="mt-3 x-small text-muted">
                Tỷ lệ lấp đầy: <span class="fw-bold" id="label-occupancy-rate">0%</span>
            </div>
        </div>
        <div class="glass-card border-start border-warning border-4">
            <div class="d-flex justify-content-between">
                <div>
                    <div class="stat-label mb-1">Doanh thu dự kiến</div>
                    <div class="stat-value text-warning" id="stat-revenue">0đ</div>
                </div>
                <div class="stat-icon bg-warning bg-opacity-10 text-warning">
                    <i class="bi bi-wallet2"></i>
                </div>
            </div>
            <div class="mt-3 x-small text-muted">
                Kỳ thanh toán: <span class="fw-bold">Tháng @DateTime.Now.Month</span>
            </div>
        </div>
        <div class="glass-card border-start border-danger border-4">
            <div class="d-flex justify-content-between">
                <div>
                    <div class="stat-label mb-1">Yêu cầu chờ xử lý</div>
                    <div class="stat-value text-danger" id="stat-requests">0</div>
                </div>
                <div class="stat-icon bg-danger bg-opacity-10 text-danger">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                </div>
            </div>
            <div class="mt-3 x-small text-muted text-danger fw-bold">
                Cần xử lý ngay!
            </div>
        </div>
    </div>

    <div class="row g-4 mt-2">
        <div class="col-lg-8">
            <div class="glass-card">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h3 class="fw-bold fs-5"><i class="bi bi-cash-stack text-success me-2"></i>Tổng doanh thu tháng @DateTime.Now.Month</h3>
                    <div class="d-flex gap-2">
                         <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 py-2 px-3">
                            <i class="bi bi-check-circle-fill me-1"></i> <span id="dash-paid-count">0</span> Đã đóng
                        </span>
                        <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 py-2 px-3">
                            <i class="bi bi-exclamation-circle-fill me-1"></i> <span id="dash-unpaid-count">0</span> Chưa đóng
                        </span>
                    </div>
                </div>
                
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <div class="p-3 rounded-4 bg-secondary bg-opacity-10 border border-secondary border-opacity-10 d-flex align-items-center">
                            <div class="stat-icon bg-primary bg-opacity-10 text-primary me-3" style="width: 48px; height: 48px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem;">
                                <i class="bi bi-calculator"></i>
                            </div>
                            <div>
                                <div class="text-main small opacity-75">Tổng tiền hóa đơn</div>
                                <div class="fw-bold fs-5 text-main" id="dash-total-expected">0đ</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="p-3 rounded-4 bg-success bg-opacity-10 border border-success border-opacity-25 d-flex align-items-center">
                            <div class="stat-icon bg-success text-white me-3" style="width: 48px; height: 48px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem;">
                                <i class="bi bi-piggy-bank"></i>
                            </div>
                            <div>
                                <div class="text-success small">Thực thu (Đã thu)</div>
                                <div class="fw-bold fs-5 text-success" id="dash-total-collected">0đ</div>
                            </div>
                        </div>
                    </div>
                </div>

                <h4 class="fw-bold fs-6 mb-3">Các khoản thu gần đây</h4>
                <div class="table-container">
                    <table class="premium-table">
                        <thead>
                            <tr>
                                <th>PHÒNG</th>
                                <th>SỐ TIỀN</th>
                                <th>HÌNH THỨC</th>
                                <th>THỜI GIAN</th>
                            </tr>
                        </thead>
                        <tbody id="dash-recent-payments">
                            <!-- Loading placeholder -->
                            <tr><td colspan="4" class="text-center py-4 text-muted">Đang tải dữ liệu tài chính...</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="glass-card">
                <h3 class="fw-bold fs-5 mb-4">Tỷ lệ lấp đầy</h3>
                <div style="position: relative; height: 250px;">
                    <canvas id="occupancyChart"></canvas>
                </div>
                <div class="mt-4">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="small text-muted"><i class="bi bi-circle-fill me-2" style="color: #6366f1;"></i> Đang ở</span>
                        <span class="fw-bold" id="label-occupied">0</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span class="small text-muted"><i class="bi bi-circle-fill me-2" style="color: #e2e8f0;"></i> Trống</span>
                        <span class="fw-bold" id="label-vacant">0</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="row g-4 mt-2">
        <div class="col-lg-12">
            <div class="glass-card">
                <h3 class="fw-bold fs-5 mb-4">Biểu đồ doanh thu 6 tháng gần đây</h3>
                <div style="position: relative; height: 350px;">
                    <canvas id="revenueChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</section>
