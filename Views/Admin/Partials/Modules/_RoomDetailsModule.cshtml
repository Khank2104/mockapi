<!-- Room Details Module -->
<section id="module-room-details" class="module-section d-none">
    <div class="d-flex align-items-center gap-3 mb-4">
        <button class="btn btn-sm btn-outline-secondary rounded-circle" onclick="switchModule('motels')">
            <i class="bi bi-arrow-left"></i>
        </button>
        <h2 class="fw-bold fs-4 mb-0">Quản lý chi tiết: <span id="detail-room-code" class="text-primary">---</span></h2>
    </div>

    <div class="row g-4">
        <!-- Left: Room Settings -->
        <div class="col-lg-6">
            <div class="glass-card h-100">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h3 class="fw-bold fs-5 mb-0"><i class="bi bi-gear-fill me-2"></i>Cấu hình thuê</h3>
                    <button class="btn btn-sm btn-premium px-3" onclick="saveRoomSettings()">Lưu cấu hình</button>
                </div>
                <form id="roomSettingsForm" class="row g-3">
                    <input type="hidden" name="RoomId" id="settings-roomId">
                    <div class="col-md-6">
                        <label class="form-label small fw-bold">GIÁ THUÊ CƠ BẢN</label>
                        <input type="number" name="BaseRent" class="form-control">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-bold">TIỀN CỌC</label>
                        <input type="number" name="DepositAmount" class="form-control">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-bold text-primary">SỐ NGƯỜI Ở TỐI ĐA</label>
                        <input type="number" name="StandardOccupants" class="form-control">
                        <div class="x-small text-muted mt-1">Phụ thu tính từ người thứ 3.</div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-bold">PHỤ THU NGƯỜI THÊM</label>
                        <input type="number" name="ExtraOccupantFee" class="form-control">
                    </div>
                    <div class="col-12 mt-3">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" name="ApplyExtraOccupantFee" id="applyExtraFee">
                            <label class="form-check-label small fw-bold" for="applyExtraFee">Áp dụng phụ thu khi vượt số người</label>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <!-- Right: Service Pricing -->
        <div class="col-lg-6">
            <div class="glass-card h-100">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h3 class="fw-bold fs-5 mb-0"><i class="bi bi-lightning-charge-fill me-2"></i>Phí dịch vụ</h3>
                    <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3 py-2 small">Theo hệ thống</span>
                </div>
                <div id="room-services-list" class="vstack gap-3">
                    <!-- Services will be loaded here -->
                    <div class="text-center py-4 text-muted">Đang tải cấu hình dịch vụ...</div>
                </div>
            </div>
        </div>

        <!-- Bottom: Occupants Management -->
        <div class="col-12">
            <div class="glass-card">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h3 class="fw-bold fs-5 mb-0"><i class="bi bi-people-fill me-2"></i>Thành viên trong phòng</h3>
                    <button class="btn btn-sm btn-outline-primary px-3 rounded-pill" onclick="showAddOccupantModal()">
                        <i class="bi bi-plus-lg"></i> Thêm người ở
                    </button>
                </div>
                <div class="table-container">
                    <table class="premium-table">
                        <thead>
                            <tr>
                                <th>HỌ TÊN</th>
                                <th>QUAN HỆ</th>
                                <th>NGÀY VÀO</th>
                                <th>SỐ ĐIỆN THOẠI</th>
                                <th>HÀNH ĐỘNG</th>
                            </tr>
                        </thead>
                        <tbody id="occupants-list-container">
                            <tr><td colspan="5" class="text-center py-4 text-muted">Chưa có thành viên nào.</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</section>
