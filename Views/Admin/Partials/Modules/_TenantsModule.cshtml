<!-- Tenants Module -->
<section id="module-tenants" class="module-section d-none">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold fs-4">Danh sách Khách thuê</h2>
        <button class="btn btn-premium" onclick="showAddTenantModal()">
            <i class="bi bi-person-plus-fill"></i>
            <span>Thêm khách thuê</span>
        </button>
    </div>
    <div class="glass-card">
        <div class="mb-4">
            <input type="text" class="form-control" placeholder="Tìm kiếm theo tên, CCCD hoặc SĐT..." style="border-radius: 12px; padding: 0.75rem 1.25rem;">
        </div>
        <div class="table-container">
            <table class="premium-table">
                <thead>
                    <tr>
                        <th>HỌ TÊN</th>
                        <th>PHÒNG</th>
                        <th>LIÊN HỆ</th>
                        <th>TRẠNG THÁI</th>
                        <th>THAO TÁC</th>
                    </tr>
                </thead>
                <tbody id="tenant-list-container">
                    <tr><td colspan="5" class="text-center py-5 text-muted">Đang tải...</td></tr>
                </tbody>
            </table>
        </div>
    </div>
</section>
