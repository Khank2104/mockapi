<!-- Tenants Module -->
<section id="module-tenants" class="module-section d-none">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div class="d-flex align-items-center gap-3">
            <h2 class="fw-bold fs-4 mb-0">Danh sách Khách thuê</h2>
            <div id="tenant-motel-badge" class="badge bg-primary bg-opacity-10 text-primary rounded-pill d-none">
                <i class="bi bi-building me-1"></i> <span id="tenant-selected-motel-name">--</span>
            </div>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-sm btn-outline-secondary rounded-pill px-3" onclick="changeGlobalMotel('tenants')">
                <i class="bi bi-arrow-left-right me-1"></i> Đổi khu trọ
            </button>
            <div class="search-box bg-white bg-opacity-50 rounded-pill px-3 py-2 border">
                <i class="bi bi-search text-muted me-2"></i>
                <input type="text" id="tenant-search-input" class="border-0 bg-transparent" placeholder="Tìm tên, SĐT, CCCD..." onkeyup="if(event.key==='Enter') loadTenantsData(1, _globalSelectedMotelId)">
            </div>
            <button class="btn btn-premium" onclick="showAddTenantModal()">
                <i class="bi bi-person-plus-fill"></i>
                <span>Thêm mới</span>
            </button>
        </div>
    </div>
    <!-- Tenant Grid Container -->
    <div id="tenant-list-container" class="row g-4">
        <!-- Cards will be dynamically loaded here -->
        <div class="col-12 text-center py-5 text-muted">
            <div class="spinner-border text-primary mb-3" role="status"></div>
            <p>Đang tải danh sách khách thuê...</p>
        </div>
    </div>
        
        <!-- Pagination Controls -->
        <div class="d-flex justify-content-between align-items-center mt-4 px-3">
            <div class="text-muted small">
                Hiển thị <span id="tenant-range">0-0</span> trong <span id="tenant-total">0</span> khách thuê
            </div>
            <nav>
                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item" id="tenant-prev-btn">
                        <a class="page-item btn btn-outline-primary rounded-pill px-3 me-2" href="javascript:void(0)" onclick="changeTenantPage(-1)">Trước</a>
                    </li>
                    <li class="page-item active"><span class="page-link rounded-circle mx-1" id="tenant-current-page">1</span></li>
                    <li class="page-item" id="tenant-next-btn">
                        <a class="page-item btn btn-outline-primary rounded-pill px-3 ms-2" href="javascript:void(0)" onclick="changeTenantPage(1)">Sau</a>
                    </li>
                </ul>
            </nav>
        </div>
    </div>
</section>
