<!-- Contracts Module -->
<section id="module-contracts" class="module-section d-none">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div class="d-flex align-items-center gap-3">
            <h2 class="fw-bold fs-4 mb-0">Quản lý Hợp đồng</h2>
            <div id="contract-motel-badge" class="badge bg-primary bg-opacity-10 text-primary rounded-pill d-none px-3 py-2">
                <i class="bi bi-building me-1"></i> <span id="contract-selected-motel-name">--</span>
            </div>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-sm btn-outline-secondary rounded-pill px-3" onclick="changeGlobalMotel('contracts')">
                <i class="bi bi-arrow-left-right me-1"></i> Đổi khu trọ
            </button>
            <input type="hidden" id="contract-motel-filter" value="0">
            <button class="btn btn-premium" onclick="showAddContractModal()">
                <i class="bi bi-file-earmark-plus-fill me-2"></i> Tạo mới
            </button>
        </div>
    </div>
    <div id="contracts-list-container" class="row g-4 justify-content-center">
        <div class="col-12 text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2 text-muted">Đang tải danh sách hợp đồng...</p>
        </div>
    </div>
        
    <!-- Pagination Controls -->
    <div class="d-flex justify-content-between align-items-center mt-4 px-3">
        <div class="text-muted small">
            Hiển thị <span id="contract-range">0-0</span> trong <span id="contract-total">0</span> hợp đồng
        </div>
        <nav>
            <ul class="pagination pagination-sm mb-0">
                <li class="page-item" id="contract-prev-btn">
                    <a class="page-item btn btn-outline-primary rounded-pill px-3 me-2" href="javascript:void(0)" onclick="changeContractPage(-1)">Trước</a>
                </li>
                <li class="page-item active"><span class="page-link rounded-circle mx-1" id="contract-current-page">1</span></li>
                <li class="page-item" id="contract-next-btn">
                    <a class="page-item btn btn-outline-primary rounded-pill px-3 ms-2" href="javascript:void(0)" onclick="changeContractPage(1)">Sau</a>
                </li>
            </ul>
        </nav>
    </div>
</section>
