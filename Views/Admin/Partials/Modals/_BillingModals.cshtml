<!-- Modal: Invoice Details -->
<div class="modal fade" id="invoiceDetailsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content glass-card border-0 p-3">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold fs-4"><i class="bi bi-file-earmark-text text-primary me-2"></i>Chi tiết Hóa đơn</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="current-invoice-id" value="0">
                <input type="hidden" id="current-proof-path" value="">
                <div id="invoice-detail-content">
                    <!-- Dynamic content will be loaded here -->
                    <div class="text-center py-5">
                        <div class="spinner-border text-primary" role="status"></div>
                        <p class="mt-2 text-muted">Đang tải chi tiết hóa đơn...</p>
                    </div>
                </div>

                <!-- Payment Proof Section (Hidden by default) -->
                <div id="payment-proof-container" class="d-none mt-4 p-3 rounded-4 bg-warning bg-opacity-10 border border-warning border-opacity-25">
                    <div class="d-flex align-items-center gap-2 mb-3">
                        <i class="bi bi-shield-check text-warning fs-4"></i>
                        <h6 class="mb-0 fw-bold">Minh chứng thanh toán</h6>
                    </div>
                    <div class="text-center mb-3">
                        <img id="payment-proof-img" src="" class="img-fluid rounded-3 shadow-sm border cursor-pointer" 
                             style="max-height: 300px; object-fit: contain;" onclick="window.open(this.src, '_blank')">
                        <p class="small text-muted mt-2"><i class="bi bi-info-circle me-1"></i> Nhấn vào ảnh để xem kích thước lớn</p>
                    </div>
                    <div id="verify-payment-form" class="bg-secondary bg-opacity-10 rounded-3 p-3 mb-3 border border-secondary border-opacity-10 d-none">
                        <label class="form-label small fw-bold text-main opacity-75">Số tiền thực nhận (VNĐ):</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0">₫</span>
                            <input type="number" id="verify-actual-amount" class="form-control border-start-0 fw-bold text-primary" placeholder="Nhập số tiền...">
                        </div>
                        <p class="x-small text-muted mt-2 mb-0"><i class="bi bi-info-circle me-1"></i> Để trống nếu khách đã trả đủ 100%.</p>
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn btn-success flex-grow-1 rounded-pill" onclick="verifyInvoicePayment(true)">
                            <i class="bi bi-check-circle me-1"></i> Phê duyệt
                        </button>
                        <button class="btn btn-outline-danger flex-grow-1 rounded-pill" onclick="verifyInvoicePayment(false)">
                            <i class="bi bi-x-circle me-1"></i> Từ chối
                        </button>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-0 pt-0 mt-2 d-flex justify-content-between">
                <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Đóng</button>
                <div class="d-flex gap-2">
                    <button type="button" class="btn btn-outline-success rounded-pill px-3" onclick="openQRPaymentPage()">
                        <i class="bi bi-qr-code me-2"></i> QR Thanh toán
                    </button>
                    <button type="button" class="btn btn-premium px-4" id="btnExportExcel">
                        <i class="bi bi-file-earmark-excel me-2"></i> Xuất Excel
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal: Record Meter -->
<div class="modal fade" id="recordMeterModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content glass-card border-0 p-3 overflow-hidden">
            <div class="modal-header border-0 pb-0">
                <div>
                    <h5 class="fw-bold mb-1">Ghi chỉ số: <span id="record-room-code" class="text-primary"></span></h5>
                    <p class="text-muted x-small mb-0">Nhập chỉ số điện/nước thực tế cho kỳ thanh toán hiện tại.</p>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body pt-4">
                <form id="recordMeterForm">
                    <input type="hidden" id="record-roomId">
                    
                    <div class="row g-4 mb-4">
                        <!-- Điện -->
                        <div class="col-md-6">
                            <div class="p-4 bg-secondary bg-opacity-10 rounded-4 h-100 border border-secondary border-opacity-10">
                                <h6 class="fw-bold text-warning mb-4 d-flex align-items-center">
                                    <span class="bg-warning bg-opacity-10 p-2 rounded-3 me-2"><i class="bi bi-lightning-charge-fill"></i></span>
                                    Chỉ số Điện
                                </h6>
                                <input type="hidden" id="record-elec-serviceId">
                                <div class="mb-4">
                                    <label class="form-label x-small fw-bold text-main opacity-50 text-uppercase ls-1">Số cũ (kWh)</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-transparent border-end-0 text-muted"><i class="bi bi-clock-history"></i></span>
                                        <input type="number" id="record-elec-prev" class="form-control rounded-end-3 py-2 bg-transparent border-start-0 text-main" readonly>
                                    </div>
                                </div>
                                <div class="mb-2">
                                    <label class="form-label x-small fw-bold text-primary text-uppercase ls-1">Số mới (kWh)</label>
                                    <div class="input-group shadow-sm rounded-3 overflow-hidden">
                                        <span class="input-group-text bg-primary text-white border-0"><i class="bi bi-pencil-square"></i></span>
                                        <input type="number" id="record-elec-curr" class="form-control py-2 border-0 fw-bold" placeholder="0.0" oninput="calculateElecUsage()">
                                    </div>
                                </div>
                                <div class="mt-3 py-2 px-3 rounded-pill bg-warning bg-opacity-10 text-warning x-small fw-bold d-none text-center animate-fade-in" id="usage-elec-container">
                                    <i class="bi bi-activity me-1"></i> Tiêu thụ: <span id="usage-elec-value">0</span> <span id="usage-elec-unit">kWh</span>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Nước -->
                        <div class="col-md-6">
                            <div class="p-4 bg-secondary bg-opacity-10 rounded-4 h-100 border border-secondary border-opacity-10">
                                <h6 class="fw-bold text-info mb-4 d-flex align-items-center">
                                    <span class="bg-info bg-opacity-10 p-2 rounded-3 me-2"><i class="bi bi-droplet-fill"></i></span>
                                    Chỉ số Nước
                                </h6>
                                <input type="hidden" id="record-water-serviceId">
                                <div class="mb-4">
                                    <label class="form-label x-small fw-bold text-main opacity-50 text-uppercase ls-1">Số cũ (m³)</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-transparent border-end-0 text-muted"><i class="bi bi-clock-history"></i></span>
                                        <input type="number" id="record-water-prev" class="form-control rounded-end-3 py-2 bg-transparent border-start-0 text-main" readonly>
                                    </div>
                                </div>
                                <div class="mb-2">
                                    <label class="form-label x-small fw-bold text-primary text-uppercase ls-1">Số mới (m³)</label>
                                    <div class="input-group shadow-sm rounded-3 overflow-hidden">
                                        <span class="input-group-text bg-primary text-white border-0"><i class="bi bi-pencil-square"></i></span>
                                        <input type="number" id="record-water-curr" class="form-control py-2 border-0 fw-bold" placeholder="0.0" oninput="calculateWaterUsage()">
                                    </div>
                                </div>
                                <div class="mt-3 py-2 px-3 rounded-pill bg-info bg-opacity-10 text-info x-small fw-bold d-none text-center animate-fade-in" id="usage-water-container">
                                    <i class="bi bi-activity me-1"></i> Tiêu thụ: <span id="usage-water-value">0</span> <span id="usage-water-unit">m³</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <button type="button" id="btnSubmitReading" class="btn btn-premium w-100 py-3 shadow-premium" onclick="submitMeterReading()">
                        <span class="btn-text">Lưu chỉ số điện & nước</span>
                        <span class="spinner-border spinner-border-sm d-none" role="status" aria-hidden="true"></span>
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
